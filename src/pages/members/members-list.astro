---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import MembersNav from "../../components/MembersNav.astro";
import Footer from "../../components/Footer.astro";

const currentPath = "/members/members-list";

const WORKER_URL = import.meta.env.HIVE_WORKER_URL ?? "https://tbc-sheets-worker.YOUR_SUBDOMAIN.workers.dev";
---

<Base
  title="Members List"
  description="Current TBC members list."
>
  <Nav slot="nav" currentPath={currentPath} />

  <div class="page-header">
    <div class="container page-header-content">
      <h1>Members List</h1>
      <p>Current active members of the Toronto Beekeepers Collective.</p>
    </div>
  </div>

  <MembersNav currentPath={currentPath} />

  <style>
    .members-section { padding: 2rem 1rem; }
    .members-wrap { max-width: 1400px; margin: 0 auto; }
    .members-wrap .table-wrap { overflow-x: auto; }
    .members-wrap table { font-size: 0.82rem; }
    .members-wrap thead th {
      padding: 0.6rem 0.75rem;
      white-space: normal;
      word-break: break-word;
      min-width: 80px;
    }
    .members-wrap tbody td {
      padding: 0.55rem 0.75rem;
      word-break: break-word;
    }
    /* Give name column a bit more room */
    .members-wrap thead th:first-child,
    .members-wrap tbody td:first-child { min-width: 120px; }
    /* Squish committees and swarm brigade to fit content */
    .members-wrap thead th:nth-child(4),
    .members-wrap tbody td:nth-child(4),
    .members-wrap thead th:nth-child(6),
    .members-wrap tbody td:nth-child(6) { min-width: 0; width: 1%; }
    /* Thicker rows */
    .members-wrap tbody td { padding: 0.9rem 0.75rem; }
    /* Tags for committees and swarm brigade */
    .cell-tags { display: flex; flex-direction: column; gap: 0.25rem; }
    .cell-tag {
      display: inline-block;
      background: var(--amber-light);
      color: var(--charcoal);
      border-radius: 3px;
      padding: 0.15rem 0.45rem;
      font-size: 0.78rem;
      white-space: nowrap;
    }
  </style>

  <section class="members-section">
    <div class="members-wrap">

      <div class="filters" style="margin-bottom: 1.5rem;">
        <div class="filter-group" style="flex:1; max-width: 360px;">
          <label for="search-members">Search</label>
          <input type="text" id="search-members" placeholder="Search by name..." />
        </div>
        <div class="filter-group">
          <label for="filter-col">Filter column</label>
          <select id="filter-col">
            <option value="">All columns</option>
          </select>
        </div>
        <div class="filter-group" style="justify-content:flex-end;">
          <button id="reset-members" class="btn btn-outline-dark" style="align-self:flex-end;">Reset</button>
        </div>
      </div>

      <div id="loading-state" class="loading">Loading members list...</div>
      <div id="error-state" class="error-msg" style="display:none;"></div>

      <div id="members-content" style="display:none;">
        <p id="members-count" style="color:var(--charcoal-mid); font-size:0.88rem; margin-bottom:0.75rem;"></p>
        <div class="table-wrap">
          <table>
            <thead id="members-thead"></thead>
            <tbody id="members-tbody"></tbody>
          </table>
        </div>
        <p id="members-empty" style="display:none; text-align:center; padding:2rem; color:var(--charcoal-mid);">
          No members match your search.
        </p>
      </div>

      <!-- Stub notice — remove once Worker/sheet is configured -->
      <div id="stub-notice" class="card" style="display:none; border-left: 4px solid var(--amber); max-width:560px;">
        <h4 style="color:var(--amber-dark); margin-bottom:0.5rem;">Schema not yet configured</h4>
        <p style="margin-bottom:0; font-size:0.92rem;">
          The members list Google Sheet schema hasn't been provided yet. Once you share the column headers,
          this page can be fully wired up. The Worker endpoint <code>/members</code> is already scaffolded
          and just needs the Sheet ID added. See <code>SETUP.md</code> for instructions.
        </p>
      </div>

    </div>
  </section>

  <Footer slot="footer" />

</Base>

<script define:vars={{ WORKER_URL }}>
  const $ = id => document.getElementById(id);

  let allRows = [];
  let headers = [];

  async function fetchMembers() {
    try {
      const res = await fetch(`${WORKER_URL}/members`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const json = await res.json();

      headers = json.headers ?? [];
      allRows = json.rows   ?? [];

      if (headers.length === 0) {
        $("loading-state").style.display = "none";
        $("stub-notice").style.display   = "block";
        return;
      }

      init();
    } catch (err) {
      $("loading-state").style.display = "none";
      $("error-state").style.display   = "block";
      $("error-state").textContent     = `Failed to load members list: ${err.message}`;
    }
  }

  function init() {
    $("loading-state").style.display    = "none";
    $("members-content").style.display  = "block";

    // Build thead
    const tr = document.createElement("tr");
    headers.forEach(h => {
      const th = document.createElement("th");
      th.textContent = h;
      tr.appendChild(th);
    });
    $("members-thead").appendChild(tr);

    // Populate filter-col
    const selCol = $("filter-col");
    headers.forEach((h, i) => {
      const opt = document.createElement("option");
      opt.value = String(i);
      opt.textContent = h;
      selCol.appendChild(opt);
    });

    render();
  }

  function getFiltered() {
    const query  = $("search-members").value.trim().toLowerCase();
    const colIdx = $("filter-col").value === "" ? null : parseInt($("filter-col").value);

    if (!query) return allRows;

    return allRows.filter(row => {
      if (colIdx !== null) {
        return String(row[headers[colIdx]] ?? "").toLowerCase().includes(query);
      }
      return Object.values(row).some(v => String(v ?? "").toLowerCase().includes(query));
    });
  }

  function render() {
    const rows = getFiltered();
    const tbody = $("members-tbody");
    tbody.innerHTML = "";

    $("members-count").textContent = `${rows.length} of ${allRows.length} members`;

    if (rows.length === 0) {
      $("members-empty").style.display = "block";
      return;
    }
    $("members-empty").style.display = "none";

    rows.forEach(row => {
      const tr = document.createElement("tr");
      headers.forEach(h => {
        const td = document.createElement("td");
        const val = row[h] ?? "";
        if ((h === "Swarm Brigade" || h === "Committees") && val.includes(",")) {
          const wrap = document.createElement("div");
          wrap.className = "cell-tags";
          val.split(",").forEach(item => {
            const tag = document.createElement("span");
            tag.className = "cell-tag";
            tag.textContent = item.trim();
            wrap.appendChild(tag);
          });
          td.appendChild(wrap);
        } else if ((h === "Swarm Brigade" || h === "Committees") && val) {
          const wrap = document.createElement("div");
          wrap.className = "cell-tags";
          const tag = document.createElement("span");
          tag.className = "cell-tag";
          tag.textContent = val.trim();
          wrap.appendChild(tag);
          td.appendChild(wrap);
        } else {
          td.textContent = val;
        }
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });
  }

  $("search-members").addEventListener("input", render);
  $("filter-col").addEventListener("change", render);
  $("reset-members").addEventListener("click", () => {
    $("search-members").value = "";
    $("filter-col").value = "";
    render();
  });

  fetchMembers();
</script>
