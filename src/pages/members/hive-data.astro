---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import MembersNav from "../../components/MembersNav.astro";
import Footer from "../../components/Footer.astro";

const currentPath = "/members/hive-data";

const WORKER_URL = import.meta.env.HIVE_WORKER_URL ?? "https://tbc-sheets-worker.YOUR_SUBDOMAIN.workers.dev";
---

<Base
  title="Hive Data"
  description="Browse and filter hive visit records for TBC colonies."
>
  <Nav slot="nav" currentPath={currentPath} />

  <div class="page-header">
    <div class="container page-header-content">
      <h1>Hive Data</h1>
      <p>Colony visit records, health status, mite counts, and treatments — filterable by location and colony.</p>
    </div>
  </div>

  <MembersNav currentPath={currentPath} />

  <section class="section">
    <div class="container">

      <!-- Filters -->
      <div class="filters" id="filters">
        <div class="filter-group">
          <label for="filter-location">Location</label>
          <select id="filter-location">
            <option value="">All Locations</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-colony">Colony</label>
          <select id="filter-colony">
            <option value="">All Colonies</option>
          </select>
        </div>
        <div class="filter-group">
          <label>Date Range</label>
          <button type="button" id="dp-trigger" class="btn btn-outline-dark dp-trigger-btn">
            <span id="dp-label">All dates</span>
          </button>
          <!-- Hidden native inputs — values kept in sync for getFiltered() -->
          <input type="date" id="filter-date-from" style="display:none" />
          <input type="date" id="filter-date-to"   style="display:none" />
        </div>
        <div class="filter-group">
          <label for="filter-status">Status</label>
          <select id="filter-status">
            <option value="">All Statuses</option>
            <option value="strong">Strong</option>
            <option value="neutral">Neutral</option>
            <option value="weak">Weak</option>
          </select>
        </div>
        <div class="filter-group" style="justify-content: flex-end;">
          <button id="filter-reset" class="btn btn-outline-dark" style="align-self:flex-end;">Reset</button>
        </div>
      </div>

      <!-- Loading / error states -->
      <div id="loading-state" class="loading">Loading hive data...</div>
      <div id="error-state" class="error-msg" style="display:none;"></div>

      <!-- Charts area -->
      <div id="charts-area" style="display:none;">

        <!-- Visit Calendar -->
        <div class="chart-container" style="margin-bottom: 1.25rem;">
          <div class="cal-nav-header">
            <span class="chart-title" style="margin:0;">Hive Visit Calendar</span>
            <div class="cal-controls">
              <button id="cal-prev" class="btn btn-outline-dark btn-sm" aria-label="Previous">&#8249;</button>
              <span id="cal-label" class="cal-label"></span>
              <button id="cal-next" class="btn btn-outline-dark btn-sm" aria-label="Next">&#8250;</button>
              <button id="cal-toggle" class="btn btn-outline-dark btn-sm">Monthly View</button>
            </div>
          </div>
          <div id="calendar-body"></div>
          <div class="cal-legend">
            <span><span class="cal-swatch" style="background:#2E7D32;"></span> Strong</span>
            <span><span class="cal-swatch" style="background:#F57F17;"></span> Neutral</span>
            <span><span class="cal-swatch" style="background:#C62828;"></span> Weak</span>
            <span class="cal-legend-hint">Click a square to jump to that visit</span>
          </div>
        </div>

        <!-- Mite chart -->
        <div id="mite-chart-wrap" class="chart-container" style="display:none; margin-bottom: 0;">
          <div class="chart-title">Mite Count Over Time</div>
          <canvas id="chart-mites" height="90"></canvas>
        </div>

      </div>

      <!-- Summary row -->
      <div id="summary-row" style="display:none;" class="summary-row">
        <div class="summary-stat">
          <span id="stat-visits">0</span>
          <span>Visits shown</span>
        </div>
        <div class="summary-stat">
          <span id="stat-colonies">0</span>
          <span>Colonies</span>
        </div>
        <div class="summary-stat">
          <span id="stat-locations">0</span>
          <span>Locations</span>
        </div>
        <div class="summary-stat">
          <span id="stat-mite-avg">—</span>
          <span>Avg mite count</span>
        </div>
      </div>

      <!-- Table -->
      <div id="table-area" style="display:none;">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Location</th>
                <th>Colony</th>
                <th>Comments</th>
                <th>Mite Count</th>
                <th>Treatment</th>
                <th>Feed</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
        </div>
        <p id="table-empty" style="display:none; text-align:center; padding:2rem; color:var(--charcoal-mid);">
          No records match your filters.
        </p>
      </div>

    </div>
  </section>

  <!-- Floating tooltip -->
  <div id="cal-tooltip" role="tooltip" aria-hidden="true"></div>

  <!-- Date range picker panel -->
  <div id="dp-panel" style="display:none;" aria-label="Date range picker">

    <!-- Calendar view -->
    <div id="dp-cal-view">
      <div class="dp-panel-header">
        <button type="button" id="dp-prev" class="btn btn-outline-dark btn-sm">&#8249;</button>
        <button type="button" id="dp-header-btn" class="dp-header-btn" title="Click to pick a specific date">
          <span id="dp-step-label">Start Date</span>
          <span class="dp-header-sep">—</span>
          <span id="dp-month-nav-label"></span>
          <span class="dp-header-caret">▾</span>
        </button>
        <button type="button" id="dp-next" class="btn btn-outline-dark btn-sm">&#8250;</button>
      </div>
      <div id="dp-months"></div>
      <div class="dp-panel-footer">
        <span id="dp-status"></span>
        <button type="button" id="dp-clear" class="btn btn-outline-dark btn-sm">Clear</button>
      </div>
    </div>

    <!-- Dropdown: year / month / day columns -->
    <div id="dp-dropdown" style="display:none;">
      <div class="dp-dd-header">
        <span id="dp-dd-title"></span>
      </div>
      <div class="dp-dd-cols">
        <div class="dp-dd-col-wrap">
          <div class="dp-dd-col-label">Year</div>
          <div id="dp-col-year"  class="dp-dd-col"></div>
        </div>
        <div class="dp-dd-col-wrap">
          <div class="dp-dd-col-label">Month</div>
          <div id="dp-col-month" class="dp-dd-col"></div>
        </div>
        <div class="dp-dd-col-wrap">
          <div class="dp-dd-col-label">Day</div>
          <div id="dp-col-day"   class="dp-dd-col"></div>
        </div>
      </div>
      <div class="dp-dd-footer">
        <button type="button" id="dp-dd-cancel" class="btn btn-outline-dark btn-sm">Cancel</button>
        <button type="button" id="dp-dd-select" class="btn btn-primary btn-sm">Select</button>
      </div>
    </div>

  </div>

  <Footer slot="footer" />
</Base>

<script define:vars={{ WORKER_URL }}>
  const COL = {
    LOCATION:  "location",
    COLONY:    "colony",
    STATUS:    "status",
    MITE:      "mite_count",
    TREATMENT: "treatment",
    FEED:      "feed",
    COMMENTS:  "comments",
    DATE:      "date",
  };

  // ── Status helpers ────────────────────────────────────────────────────
  function normaliseStatus(raw) {
    if (!raw) return "neutral";
    const s = raw.toLowerCase();
    if (s.includes("strong")) return "strong";
    if (s.includes("weak"))   return "weak";
    return "neutral";
  }

  function statusLabel(status) {
    return { strong: "Strong", neutral: "Neutral", weak: "Weak" }[status] ?? "Neutral";
  }

  function statusBadge(status) {
    const map = {
      strong:  ["badge-good", "Strong"],
      neutral: ["badge-mid",  "Neutral"],
      weak:    ["badge-bad",  "Weak"],
    };
    const [cls, label] = map[status] ?? map.neutral;
    const color = STATUS_COL[status] ?? STATUS_COL.neutral;
    return `<span class="badge ${cls}">${label}&nbsp;<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${color};vertical-align:middle;"></span></span>`;
  }

  const STATUS_COL = { strong: "#2E7D32", neutral: "#F57F17", weak: "#C62828" };

  // ── Date helpers ──────────────────────────────────────────────────────
  function parseDate(val) {
    if (!val) return null;
    const dmy = val.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (dmy) {
      const d = new Date(parseInt(dmy[3]), parseInt(dmy[2]) - 1, parseInt(dmy[1]));
      return isNaN(d.getTime()) ? null : d;
    }
    const d = new Date(val);
    if (isNaN(d.getTime()) || d.getFullYear() < 2000) return null;
    return d;
  }

  function fmtDate(d, opts) {
    if (!d) return "—";
    return d.toLocaleDateString("en-CA", opts ?? { year: "numeric", month: "short", day: "numeric" });
  }

  function dateKey(d) {
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
  }

  // ── State ─────────────────────────────────────────────────────────────
  let allRows  = [];
  let charts   = {};
  let calView  = "year";
  let calYear  = new Date().getFullYear();
  let calMonth = new Date().getMonth();

  // ── Date-picker state ─────────────────────────────────────────────────
  let dpFrom  = null;   // Date | null — selected start
  let dpTo    = null;   // Date | null — selected end
  let dpStep  = "from"; // "from" | "to"
  let dpLYear = new Date().getFullYear();
  let dpLMonth = 0;    // left-panel month (right = +1)

  // ── DOM refs ──────────────────────────────────────────────────────────
  const $ = id => document.getElementById(id);
  const selLocation = $("filter-location");
  const selColony   = $("filter-colony");
  const inpFrom     = $("filter-date-from");
  const inpTo       = $("filter-date-to");
  const selStatus   = $("filter-status");
  const btnReset    = $("filter-reset");
  const loadingEl   = $("loading-state");
  const errorEl     = $("error-state");
  const chartsArea  = $("charts-area");
  const miteWrap    = $("mite-chart-wrap");
  const summaryRow  = $("summary-row");
  const tableArea   = $("table-area");
  const tableBody   = $("table-body");
  const tableEmpty  = $("table-empty");
  const tooltip     = $("cal-tooltip");

  // ── Tooltip ───────────────────────────────────────────────────────────
  function showTooltip(evt, lines) {
    tooltip.innerHTML = lines.map(l => `<div>${l}</div>`).join("");
    tooltip.style.display = "block";
    positionTooltip(evt);
  }

  function positionTooltip(evt) {
    const pad = 12;
    const tw  = tooltip.offsetWidth;
    const th  = tooltip.offsetHeight;
    let   x   = evt.clientX + pad;
    let   y   = evt.clientY + pad;
    if (x + tw > window.innerWidth  - 8) x = evt.clientX - tw - pad;
    if (y + th > window.innerHeight - 8) y = evt.clientY - th - pad;
    tooltip.style.left = x + "px";
    tooltip.style.top  = y + "px";
  }

  function hideTooltip() {
    tooltip.style.display = "none";
  }

  // ── Fetch ─────────────────────────────────────────────────────────────
  async function fetchData() {
    try {
      const res = await fetch(`${WORKER_URL}/hive-data`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const json = await res.json();
      allRows = (json.rows ?? []).map((r, i) => ({ ...r, _id: i }));
      init();
    } catch (err) {
      loadingEl.style.display = "none";
      errorEl.style.display   = "block";
      errorEl.textContent     = `Failed to load hive data: ${err.message}. Make sure the Worker is deployed and HIVE_WORKER_URL is configured.`;
    }
  }

  // ── Init ─────────────────────────────────────────────────────────────
  function init() {
    loadingEl.style.display = "none";

    const locations = [...new Set(allRows.map(r => r[COL.LOCATION]).filter(Boolean))].sort();
    locations.forEach(loc => {
      const opt = document.createElement("option");
      opt.value = loc;
      opt.textContent = loc;
      selLocation.appendChild(opt);
    });

    const year = new Date().getFullYear();
    inpFrom.value = `${year}-01-01`;
    inpTo.value   = `${year}-12-31`;
    dpFrom  = new Date(year, 0, 1);
    dpTo    = new Date(year, 11, 31);
    dpLYear = year;
    dpLMonth = 0;
    dpUpdateLabel();

    render();

    chartsArea.style.display = "block";
    summaryRow.style.display = "flex";
    tableArea.style.display  = "block";
  }

  // ── Filtering ─────────────────────────────────────────────────────────
  function getFiltered() {
    const loc      = selLocation.value;
    const colony   = selColony.value;
    const from     = inpFrom.value ? new Date(inpFrom.value + "T00:00:00") : null;
    const to       = inpTo.value   ? new Date(inpTo.value   + "T23:59:59") : null;
    const statFilt = selStatus.value;

    return allRows.filter(r => {
      if (loc    && r[COL.LOCATION] !== loc)    return false;
      if (colony && r[COL.COLONY]   !== colony) return false;
      if (statFilt && normaliseStatus(r[COL.STATUS]) !== statFilt) return false;
      const d = parseDate(r[COL.DATE]);
      if (from && d && d < from) return false;
      if (to   && d && d > to)   return false;
      return true;
    });
  }

  function updateCalFromFilter() {
    const from = inpFrom.value ? new Date(inpFrom.value + "T00:00:00") : null;
    const to   = inpTo.value   ? new Date(inpTo.value   + "T00:00:00") : null;

    if (from && to) {
      // Only use monthly view when both dates are in the exact same month
      const sameMonth = from.getFullYear() === to.getFullYear() &&
                        from.getMonth()    === to.getMonth();
      if (sameMonth) {
        calView  = "month";
        calYear  = from.getFullYear();
        calMonth = from.getMonth();
      } else {
        calView = "year";
        calYear = from.getFullYear();
      }
    } else if (from) {
      calYear = from.getFullYear();
    } else {
      calView  = "year";
      calYear  = new Date().getFullYear();
      calMonth = new Date().getMonth();
    }
  }

  // ── Colony dropdown ───────────────────────────────────────────────────
  selLocation.addEventListener("change", () => {
    const loc = selLocation.value;
    const prevColony = selColony.value;
    selColony.innerHTML = "<option value=''>All Colonies</option>";
    const colonies = [...new Set(
      allRows
        .filter(r => !loc || r[COL.LOCATION] === loc)
        .map(r => r[COL.COLONY])
        .filter(Boolean)
    )].sort();
    colonies.forEach(c => {
      const opt = document.createElement("option");
      opt.value = c;
      opt.textContent = `Colony ${c}`;
      if (c === prevColony) opt.selected = true;
      selColony.appendChild(opt);
    });
    render();
  });

  selColony.addEventListener("change", render);
  selStatus.addEventListener("change", render);
  // inpFrom / inpTo are hidden; updates come only from the custom picker

  btnReset.addEventListener("click", () => {
    selLocation.value = "";
    selColony.value   = "";
    selStatus.value   = "";
    calView  = "year";
    calYear  = new Date().getFullYear();
    calMonth = new Date().getMonth();
    const year = new Date().getFullYear();
    inpFrom.value = `${year}-01-01`;
    inpTo.value   = `${year}-12-31`;
    dpFrom  = new Date(year, 0, 1);
    dpTo    = new Date(year, 11, 31);
    dpStep  = "from";
    dpLYear = year;
    dpLMonth = 0;
    dpUpdateLabel();
    updateCalFromFilter();
    selLocation.dispatchEvent(new Event("change"));
  });

  // ── Date picker ──────────────────────────────────────────────────────
  let dpDdYear, dpDdMonth, dpDdDay;

  const MONTH_NAMES = ["January","February","March","April","May","June",
                       "July","August","September","October","November","December"];

  // Infinite-loop column constants (must match CSS)
  const DD_IH = 36;   // item height px
  const DD_CH = 180;  // column visible height px
  const DD_COPIES = 7; // copies of the list — enough to scroll freely

  function dpUpdateLabel() {
    const el = $("dp-label");
    if (dpFrom && dpTo)   el.textContent = `${fmtDate(dpFrom)} – ${fmtDate(dpTo)}`;
    else if (dpFrom)      el.textContent = `${fmtDate(dpFrom)} – pick end`;
    else                  el.textContent = "All dates";
  }

  function dpOpen() {
    const seed = dpStep === "to" && dpFrom ? dpFrom : (dpFrom ?? new Date());
    dpLYear  = seed.getFullYear();
    dpLMonth = seed.getMonth();
    const rect = $("dp-trigger").getBoundingClientRect();
    const panel = $("dp-panel");
    panel.style.left = Math.min(rect.left, window.innerWidth - 310) + "px";
    panel.style.top  = (rect.bottom + window.scrollY + 6) + "px";
    $("dp-cal-view").style.display = "block";
    $("dp-dropdown").style.display = "none";
    panel.style.display = "block";
    dpRender();
  }

  function dpClose() {
    $("dp-panel").style.display   = "none";
    $("dp-dropdown").style.display = "none";
    $("dp-cal-view").style.display  = "block";
  }

  function dpRender() {
    $("dp-step-label").textContent = dpStep === "from" ? "Start Date" : "End Date";
    $("dp-month-nav-label").textContent =
      new Date(dpLYear, dpLMonth).toLocaleDateString("en-CA", { month: "long", year: "numeric" });

    const wrap = $("dp-months");
    wrap.innerHTML = "";
    wrap.appendChild(dpBuildMonthGrid(dpLYear, dpLMonth));

    $("dp-status").textContent = !dpFrom
      ? "Click a start date, or use ▾ to type one"
      : !dpTo
        ? `Start: ${fmtDate(dpFrom)} — now pick an end date`
        : `${fmtDate(dpFrom)} – ${fmtDate(dpTo)}`;
  }

  function dpBuildMonthGrid(year, month) {
    const HEADS = ["M","T","W","T","F","S","S"];
    const today = new Date(); today.setHours(0,0,0,0);
    const grid  = document.createElement("div");
    grid.className = "cal-grid dp-grid";
    HEADS.forEach(h => {
      const dh = document.createElement("div");
      dh.className = "cal-dh";
      dh.textContent = h;
      grid.appendChild(dh);
    });
    const days   = new Date(year, month + 1, 0).getDate();
    const offset = (new Date(year, month, 1).getDay() + 6) % 7;
    for (let i = 0; i < offset; i++) grid.appendChild(document.createElement("div"));
    for (let day = 1; day <= days; day++) {
      const d = new Date(year, month, day);
      const cell = document.createElement("div");
      cell.className = "dp-day";
      cell.textContent = String(day);
      if (d.getTime() === today.getTime()) cell.classList.add("dp-today");
      if (d > today) cell.classList.add("dp-future");
      const t0 = dpFrom?.getTime(), t1 = dpTo?.getTime(), dt = d.getTime();
      if (t0 && t1 && dt > t0 && dt < t1) cell.classList.add("dp-in-range");
      if (t0 && dt === t0) cell.classList.add("dp-endpoint");
      if (t1 && dt === t1) cell.classList.add("dp-endpoint");
      cell.addEventListener("click", () => dpPickDate(d));
      grid.appendChild(cell);
    }
    return grid;
  }

  function dpPickDate(d) {
    if (!dpFrom || (dpFrom && dpTo)) {
      dpFrom = d; dpTo = null; dpStep = "to";
      dpLYear = d.getFullYear(); dpLMonth = d.getMonth();
    } else {
      if (d < dpFrom) { dpTo = dpFrom; dpFrom = d; }
      else              dpTo = d;
      dpStep = "from";
      inpFrom.value = dateKey(dpFrom);
      inpTo.value   = dateKey(dpTo);
      dpUpdateLabel(); updateCalFromFilter(); render();
      dpClose(); return;
    }
    dpRender();
  }

  // ── Infinite-loop dropdown columns ───────────────────────────────────
  // Each column renders DD_COPIES copies of its list; the middle copy is
  // centred in the viewport. Scroll wraps by jumping ±2 copies worth of
  // pixels, keeping the visual position identical.

  function buildLoopCol(colEl, labels, selIdx, onChangeIdx) {
    const N = labels.length;

    // Remove old listeners (stored on element to avoid accumulation)
    if (colEl._dpScroll) colEl.removeEventListener("scroll", colEl._dpScroll);
    if (colEl._dpClick)  colEl.removeEventListener("click",  colEl._dpClick);
    colEl.innerHTML = "";

    // Render DD_COPIES copies
    for (let c = 0; c < DD_COPIES; c++) {
      labels.forEach((label, i) => {
        const el = document.createElement("div");
        el.className = "dp-dd-item";
        el.dataset.i   = i;
        el.dataset.abs = c * N + i;
        el.textContent = label;
        colEl.appendChild(el);
      });
    }

    // Centre the selected item in the middle copy
    const midCopy = Math.floor(DD_COPIES / 2);
    const targetST = (midCopy * N + selIdx) * DD_IH - (DD_CH / 2 - DD_IH / 2);
    colEl.scrollTop = Math.max(0, targetST);
    highlightCol(colEl, selIdx);

    let snapTimer;
    let lastIdx = selIdx; // track last fired index to avoid redundant callbacks

    colEl._dpScroll = () => {
      // Wrap: keep scrollTop within copies 1 … DD_COPIES-2
      const minST = N * DD_IH;
      const maxST = (DD_COPIES - 2) * N * DD_IH;
      if (colEl.scrollTop < minST)      colEl.scrollTop += (DD_COPIES - 3) * N * DD_IH;
      else if (colEl.scrollTop > maxST) colEl.scrollTop -= (DD_COPIES - 3) * N * DD_IH;

      // Determine which item is centred
      const centerST = colEl.scrollTop + DD_CH / 2 - DD_IH / 2;
      const absIdx   = Math.round(centerST / DD_IH);
      const realIdx  = ((absIdx % N) + N) % N;
      highlightCol(colEl, realIdx);

      // Only fire the callback when the index actually changes —
      // prevents dpDdDayClamped() from rebuilding the day column on
      // every scroll pixel, which was causing the infinite snap loop.
      if (realIdx !== lastIdx) {
        lastIdx = realIdx;
        onChangeIdx(realIdx);
      }

      // Snap to nearest item after scrolling settles.
      // Guard: only call scrollTo when we're not already at the target —
      // this breaks the infinite loop where each snap fires a scroll event
      // that schedules another snap.
      clearTimeout(snapTimer);
      snapTimer = setTimeout(() => {
        const snapAbs = Math.round((colEl.scrollTop + DD_CH / 2 - DD_IH / 2) / DD_IH);
        const snapTop = snapAbs * DD_IH - (DD_CH / 2 - DD_IH / 2);
        if (Math.abs(colEl.scrollTop - snapTop) > 1) {
          colEl.scrollTo({ top: snapTop, behavior: "smooth" });
        }
      }, 180);
    };
    colEl.addEventListener("scroll", colEl._dpScroll);

    // Click: smooth-scroll clicked item to centre
    colEl._dpClick = e => {
      const item = e.target.closest("[data-abs]");
      if (!item) return;
      const target = parseInt(item.dataset.abs) * DD_IH - (DD_CH / 2 - DD_IH / 2);
      colEl.scrollTo({ top: target, behavior: "smooth" });
    };
    colEl.addEventListener("click", colEl._dpClick);
  }

  function highlightCol(colEl, realIdx) {
    colEl.querySelectorAll(".dp-dd-item").forEach(el => {
      el.classList.toggle("dp-dd-sel", parseInt(el.dataset.i) === realIdx);
    });
  }

  function dpOpenDropdown() {
    const seed = (dpStep === "to" && dpTo ? dpTo : dpFrom) ?? new Date(dpLYear, dpLMonth, 1);
    dpDdYear  = seed.getFullYear();
    dpDdMonth = seed.getMonth();
    dpDdDay   = seed.getDate();
    $("dp-dd-title").textContent = dpStep === "from" ? "Pick Start Date" : "Pick End Date";
    $("dp-cal-view").style.display = "none";
    $("dp-dropdown").style.display = "block";

    const thisYear = new Date().getFullYear();
    const yearLabels = [];
    for (let y = 2020; y <= thisYear + 2; y++) yearLabels.push(String(y));

    buildLoopCol($("dp-col-year"), yearLabels, dpDdYear - 2020, idx => {
      dpDdYear = 2020 + idx;
      dpUpdateDayDisabled(); // update disabled state only — no DOM rebuild
    });

    buildLoopCol($("dp-col-month"), MONTH_NAMES, dpDdMonth, idx => {
      dpDdMonth = idx;
      dpUpdateDayDisabled(); // update disabled state only — no DOM rebuild
    });

    // Day column: always 31 items; days beyond the month's max are disabled.
    // Never rebuilt — avoids the DOM thrash that caused flickering.
    const dayLabels = Array.from({ length: 31 }, (_, i) => String(i + 1));
    buildLoopCol($("dp-col-day"), dayLabels, dpDdDay - 1, idx => {
      dpDdDay = idx + 1;
    });
    dpUpdateDayDisabled();
  }

  // Update day column disabled/selected state without touching the DOM structure.
  function dpUpdateDayDisabled() {
    const max = new Date(dpDdYear, dpDdMonth + 1, 0).getDate();
    // Clamp selected day and smoothly scroll to it if needed
    if (dpDdDay > max) {
      dpDdDay = max;
      const col = $("dp-col-day");
      const midCopy = Math.floor(DD_COPIES / 2);
      const snapTop = (midCopy * 31 + (dpDdDay - 1)) * DD_IH - (DD_CH / 2 - DD_IH / 2);
      col.scrollTo({ top: Math.max(0, snapTop), behavior: "smooth" });
    }
    $("dp-col-day").querySelectorAll(".dp-dd-item").forEach(el => {
      const n = parseInt(el.dataset.i) + 1;
      el.classList.toggle("dp-dd-disabled", n > max);
      el.classList.toggle("dp-dd-sel",      n === dpDdDay);
    });
  }

  $("dp-panel").addEventListener("click", e => e.stopPropagation());

  $("dp-header-btn").addEventListener("click", dpOpenDropdown);

  $("dp-dd-cancel").addEventListener("click", () => {
    $("dp-dropdown").style.display = "none";
    $("dp-cal-view").style.display = "block";
  });

  $("dp-dd-select").addEventListener("click", () => {
    $("dp-dropdown").style.display = "none";
    $("dp-cal-view").style.display = "block";
    dpPickDate(new Date(dpDdYear, dpDdMonth, dpDdDay));
    // If picking start: dpPickDate transitions to "End Date" calendar view (stays open)
    // If picking end:   dpPickDate closes the panel
  });

  // ── Panel open / close / nav ────────────────────────────────────────
  $("dp-trigger").addEventListener("click", e => {
    e.stopPropagation();
    $("dp-panel").style.display === "none" ? dpOpen() : dpClose();
  });

  document.addEventListener("click", () => {
    if ($("dp-panel").style.display !== "none") dpClose();
  });

  $("dp-prev").addEventListener("click", e => {
    e.stopPropagation();
    dpLMonth--; if (dpLMonth < 0) { dpLMonth = 11; dpLYear--; }
    dpRender();
  });
  $("dp-next").addEventListener("click", e => {
    e.stopPropagation();
    dpLMonth++; if (dpLMonth > 11) { dpLMonth = 0; dpLYear++; }
    dpRender();
  });
  $("dp-clear").addEventListener("click", e => {
    e.stopPropagation();
    dpFrom = null; dpTo = null; dpStep = "from";
    inpFrom.value = ""; inpTo.value = "";
    dpUpdateLabel(); updateCalFromFilter(); render(); dpClose();
  });

  // ── Calendar nav ──────────────────────────────────────────────────────
  $("cal-prev").addEventListener("click", () => {
    if (calView === "year") { calYear--; }
    else { calMonth--; if (calMonth < 0)  { calMonth = 11; calYear--; } }
    renderCalendar(getFiltered());
  });
  $("cal-next").addEventListener("click", () => {
    if (calView === "year") { calYear++; }
    else { calMonth++; if (calMonth > 11) { calMonth = 0;  calYear++; } }
    renderCalendar(getFiltered());
  });
  $("cal-toggle").addEventListener("click", () => {
    if (calView === "year") {
      calView = "month";
      // Default to the first month of the active filter range, not today
      const from = inpFrom.value ? new Date(inpFrom.value + "T00:00:00") : null;
      calYear  = from ? from.getFullYear() : new Date().getFullYear();
      calMonth = from ? from.getMonth()    : new Date().getMonth();
    } else {
      calView = "year";
    }
    renderCalendar(getFiltered());
  });

  // ── Scroll + flash table rows ─────────────────────────────────────────
  function scrollToRows(ids) {
    const trs = ids.map(id => document.getElementById("entry-" + id)).filter(Boolean);
    if (!trs.length) return;
    trs[0].scrollIntoView({ behavior: "smooth", block: "center" });
    trs.forEach(tr => {
      tr.classList.remove("row-highlight");
      void tr.offsetWidth;
      tr.classList.add("row-highlight");
    });
  }

  // ── Main render ───────────────────────────────────────────────────────
  function render() {
    const rows = getFiltered();
    renderSummary(rows);
    renderTable(rows);
    renderCalendar(rows);
    renderMiteChart(rows);
  }

  // ── Summary ───────────────────────────────────────────────────────────
  function renderSummary(rows) {
    $("stat-visits").textContent    = rows.length;
    $("stat-colonies").textContent  = new Set(rows.map(r => r[COL.COLONY])).size;
    $("stat-locations").textContent = new Set(rows.map(r => r[COL.LOCATION])).size;
    const mites = rows.map(r => parseFloat(r[COL.MITE])).filter(n => !isNaN(n));
    $("stat-mite-avg").textContent = mites.length
      ? (mites.reduce((a, b) => a + b, 0) / mites.length).toFixed(1)
      : "—";
  }

  // ── Table ─────────────────────────────────────────────────────────────
  function renderTable(rows) {
    tableBody.innerHTML = "";
    if (rows.length === 0) { tableEmpty.style.display = "block"; return; }
    tableEmpty.style.display = "none";

    const sorted = [...rows].sort((a, b) => {
      const da = parseDate(a[COL.DATE]);
      const db = parseDate(b[COL.DATE]);
      if (!da && !db) return 0;
      if (!da) return 1;
      if (!db) return -1;
      return db - da;
    });

    sorted.forEach(r => {
      const status = normaliseStatus(r[COL.STATUS]);
      const tr = document.createElement("tr");
      tr.id = "entry-" + r._id;
      tr.innerHTML = `
        <td>${fmtDate(parseDate(r[COL.DATE]))}</td>
        <td>${r[COL.LOCATION] ?? "—"}</td>
        <td>${r[COL.COLONY] ? `Colony ${r[COL.COLONY]}` : "—"}</td>
        <td style="max-width:240px; white-space:pre-wrap; font-size:0.85rem;">${r[COL.COMMENTS] ?? ""}</td>
        <td>${r[COL.MITE] ?? "—"}</td>
        <td>${r[COL.TREATMENT] ?? "—"}</td>
        <td>${r[COL.FEED] ?? "—"}</td>
        <td>${statusBadge(status)}</td>
      `;
      tableBody.appendChild(tr);
    });
  }

  // ── Calendar ──────────────────────────────────────────────────────────

  // visitMap: "YYYY-MM-DD" → { strong:[{_id,colony,location},...], neutral:[...], weak:[...] }
  function buildVisitMap(rows) {
    const map = new Map();
    rows.forEach(r => {
      const d = parseDate(r[COL.DATE]);
      if (!d) return;
      const key = dateKey(d);
      if (!map.has(key)) map.set(key, { strong: [], neutral: [], weak: [] });
      const norm = normaliseStatus(r[COL.STATUS]);
      map.get(key)[norm].push({
        _id:      r._id,
        colony:   r[COL.COLONY]   ?? "?",
        location: r[COL.LOCATION] ?? "?",
      });
    });
    return map;
  }

  const WEEK_HEADS_SHORT = ["M", "T", "W", "T", "F", "S", "S"];
  const WEEK_HEADS_LONG  = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];

  // Build a dot element (returns an HTMLElement)
  function makeDot(status, visits, dateStr) {
    const span = document.createElement("span");
    span.className = "cal-dot";
    span.style.background = STATUS_COL[status];
    const count = visits.length;
    if (count > 1) span.textContent = String(count);

    // Tooltip lines: date header + one line per visit
    const dot = `<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${STATUS_COL[status]};margin-left:3px;vertical-align:middle;"></span>`;
    const tipLines = [
      `<strong>${dateStr}</strong>`,
      ...visits.map(v => `Colony ${v.colony} @ ${v.location} — ${statusLabel(status)}${dot}`),
    ];

    span.addEventListener("mouseenter", evt => showTooltip(evt, tipLines));
    span.addEventListener("mousemove",  evt => positionTooltip(evt));
    span.addEventListener("mouseleave", hideTooltip);
    span.addEventListener("click", e => {
      e.stopPropagation();
      hideTooltip();
      scrollToRows(visits.map(v => v._id));
    });
    return span;
  }

  // Build a day cell element for the mini (year) calendar
  function makeMiniCell(day, visits, isFuture, inRange, dateStr) {
    const cell = document.createElement("div");
    cell.className = "cal-cell-mini" + (isFuture ? " cal-future" : !inRange ? " cal-grey" : "");

    const num = document.createElement("span");
    num.className = "cal-num";
    num.textContent = String(day);
    cell.appendChild(num);

    if (visits && inRange && !isFuture) {
      const dotsWrap = document.createElement("div");
      dotsWrap.className = "cal-dots-mini";
      for (const [status, list] of Object.entries(visits)) {
        if (!list.length) continue;
        dotsWrap.appendChild(makeDot(status, list, dateStr));
      }
      cell.appendChild(dotsWrap);
    }
    return cell;
  }

  // Build a day cell element for the full (month) calendar
  function makeFullCell(day, visits, isFuture, inRange, dateStr) {
    const cell = document.createElement("div");
    cell.className = "cal-cell-full" + (isFuture ? " cal-future" : !inRange ? " cal-grey" : "");

    const num = document.createElement("span");
    num.className = "cal-num-full";
    num.textContent = String(day);
    cell.appendChild(num);

    if (visits && inRange && !isFuture) {
      const dotsWrap = document.createElement("div");
      dotsWrap.className = "cal-dots-full";
      for (const [status, list] of Object.entries(visits)) {
        if (!list.length) continue;
        dotsWrap.appendChild(makeDot(status, list, dateStr));
      }
      cell.appendChild(dotsWrap);
    }
    return cell;
  }

  function buildMonthMini(year, month, visitMap, today, from, to) {
    const wrap = document.createElement("div");
    wrap.className = "cal-month";

    // Month name header — click to zoom into that month
    const header = document.createElement("div");
    header.className = "cal-month-name";
    header.textContent = new Date(year, month).toLocaleDateString("en-CA", { month: "short" });
    header.title = "Click to view full month";
    header.addEventListener("click", () => {
      calView = "month"; calMonth = month; calYear = year;
      renderCalendar(getFiltered());
    });
    wrap.appendChild(header);

    // 7-column grid
    const grid = document.createElement("div");
    grid.className = "cal-grid";

    // Day-of-week headers
    WEEK_HEADS_SHORT.forEach(h => {
      const dh = document.createElement("div");
      dh.className = "cal-dh";
      dh.textContent = h;
      grid.appendChild(dh);
    });

    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const offset      = (new Date(year, month, 1).getDay() + 6) % 7; // Mon=0

    for (let i = 0; i < offset; i++) {
      const pad = document.createElement("div");
      pad.className = "cal-cell-mini cal-pad";
      grid.appendChild(pad);
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const date    = new Date(year, month, day);
      const key     = dateKey(date);
      const visits  = visitMap.get(key) ?? null;
      const future  = date > today;
      const inRange = (!from || date >= from) && (!to || date <= to);
      const dateStr = fmtDate(date);
      grid.appendChild(makeMiniCell(day, visits, future, inRange, dateStr));
    }

    wrap.appendChild(grid);
    return wrap;
  }

  function buildMonthFull(year, month, visitMap, today, from, to) {
    const wrap = document.createElement("div");
    wrap.className = "cal-month-full";

    // 7-column grid
    const grid = document.createElement("div");
    grid.className = "cal-grid cal-grid-full";

    WEEK_HEADS_LONG.forEach(h => {
      const dh = document.createElement("div");
      dh.className = "cal-dh cal-dh-full";
      dh.textContent = h;
      grid.appendChild(dh);
    });

    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const offset      = (new Date(year, month, 1).getDay() + 6) % 7;

    for (let i = 0; i < offset; i++) {
      const pad = document.createElement("div");
      pad.className = "cal-cell-full cal-pad";
      grid.appendChild(pad);
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const date    = new Date(year, month, day);
      const key     = dateKey(date);
      const visits  = visitMap.get(key) ?? null;
      const future  = date > today;
      const inRange = (!from || date >= from) && (!to || date <= to);
      const dateStr = fmtDate(date);
      grid.appendChild(makeFullCell(day, visits, future, inRange, dateStr));
    }

    wrap.appendChild(grid);
    return wrap;
  }

  function renderCalendar(rows) {
    const visitMap  = buildVisitMap(rows);
    const today     = new Date();
    const from      = inpFrom.value ? new Date(inpFrom.value + "T00:00:00") : null;
    const to        = inpTo.value   ? new Date(inpTo.value   + "T23:59:59") : null;
    const body      = $("calendar-body");
    const labelEl   = $("cal-label");
    const toggleBtn = $("cal-toggle");

    body.innerHTML = "";

    if (calView === "year") {
      labelEl.textContent   = String(calYear);
      toggleBtn.textContent = "Monthly View";

      // Compute visible month range for this year:
      // - Default ceiling: current month for current year, Dec for past years
      // - If a date filter is active, clamp to just the months it covers
      const ceilMonth = (calYear === today.getFullYear()) ? today.getMonth() : 11;
      let startMonth = 0;
      let endMonth   = ceilMonth;

      if (from && from.getFullYear() === calYear) startMonth = Math.max(startMonth, from.getMonth());
      if (to   && to.getFullYear()   === calYear) endMonth   = Math.min(endMonth,   to.getMonth());
      // If the filter excludes this year entirely, show nothing
      if (from && from.getFullYear() > calYear) endMonth = -1;
      if (to   && to.getFullYear()   < calYear) endMonth = -1;

      const monthCount = endMonth >= startMonth ? endMonth - startMonth + 1 : 0;
      const maxCols = window.innerWidth <= 480 ? 2
                    : window.innerWidth <= 720 ? 3
                    : 4;
      const cols = Math.min(Math.max(monthCount, 1), maxCols);

      const yearGrid = document.createElement("div");
      yearGrid.className = "cal-year";
      yearGrid.style.gridTemplateColumns = `repeat(${cols}, minmax(0, 1fr))`;

      for (let m = startMonth; m <= endMonth; m++) {
        yearGrid.appendChild(buildMonthMini(calYear, m, visitMap, today, from, to));
      }
      body.appendChild(yearGrid);

    } else {
      const label = new Date(calYear, calMonth).toLocaleDateString("en-CA", { month: "long", year: "numeric" });
      labelEl.textContent   = label;
      toggleBtn.textContent = "Yearly View";
      body.appendChild(buildMonthFull(calYear, calMonth, visitMap, today, from, to));
    }
  }

  // ── Mite chart ────────────────────────────────────────────────────────
  async function renderMiteChart(rows) {
    const { Chart, registerables } = await import("https://cdn.jsdelivr.net/npm/chart.js@4/+esm");
    Chart.register(...registerables);

    const mitePoints = rows
      .map(r => {
        const d   = parseDate(r[COL.DATE]);
        const val = parseFloat(r[COL.MITE]);
        if (!d || isNaN(val)) return null;
        return {
          x: d.getTime(), y: val, _id: r._id,
          dateStr: fmtDate(d), colony: r[COL.COLONY] ?? "?", location: r[COL.LOCATION] ?? "?",
        };
      })
      .filter(Boolean)
      .sort((a, b) => a.x - b.x);

    if (mitePoints.length > 0) {
      miteWrap.style.display = "block";
      if (charts.mites) charts.mites.destroy();
      charts.mites = new Chart($("chart-mites"), {
        type: "scatter",
        data: {
          datasets: [{
            data: mitePoints,
            backgroundColor: "rgba(198,40,40,0.75)",
            borderColor: "#C62828",
            pointRadius: 6, pointHoverRadius: 8,
          }],
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                title: () => "",
                label: ctx => {
                  const p = ctx.raw;
                  return [p.dateStr, `Colony ${p.colony} @ ${p.location}`, `Mite count: ${p.y}`];
                },
              },
            },
          },
          scales: {
            x: {
              type: "linear", grid: { display: false },
              ticks: {
                maxTicksLimit: 8,
                callback: v => new Date(v).toLocaleDateString("en-CA", { month: "short", day: "numeric", year: "2-digit" }),
              },
            },
            y: {
              beginAtZero: true,
              title: { display: true, text: "Mites per 100 bees" },
              grid: { color: "rgba(0,0,0,0.06)" },
            },
          },
          onClick: (evt, elements) => {
            if (!elements.length) return;
            scrollToRows([mitePoints[elements[0].index]._id]);
          },
          onHover: (evt, elements) => {
            evt.native.target.style.cursor = elements.length ? "pointer" : "default";
          },
        },
      });
    } else {
      miteWrap.style.display = "none";
      if (charts.mites) { charts.mites.destroy(); charts.mites = null; }
    }
  }

  // ── Boot ──────────────────────────────────────────────────────────────
  fetchData();
</script>

<!--
  is:global required: these rules target elements created dynamically by JS.
  Astro scopes <style> to static template elements via data attributes;
  runtime-generated HTML won't carry those attributes, so scoped rules never match.
-->
<style is:global>
  /* ── Tooltip ────────────────────────────────────────────────────── */
  #cal-tooltip {
    display: none;
    position: fixed;
    z-index: 9999;
    background: #2B2B2B;
    color: #fff;
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    line-height: 1.5;
    pointer-events: none;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    max-width: 260px;
  }

  /* ── Calendar nav ───────────────────────────────────────────────── */
  .cal-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .cal-controls { display: flex; align-items: center; gap: 0.4rem; }

  .cal-label {
    font-weight: 600;
    font-size: 0.95rem;
    min-width: 8rem;
    text-align: center;
    color: #2B2B2B;
  }

  .btn-sm { padding: 0.2rem 0.6rem; font-size: 1.05rem; line-height: 1; }

  /* ── Year grid of months ────────────────────────────────────────── */
  .cal-year {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5rem 1.25rem;
  }

  @media (max-width: 860px) { .cal-year { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 580px) { .cal-year { grid-template-columns: repeat(2, minmax(0, 1fr)); } }

  /* ── Month block (mini) ─────────────────────────────────────────── */
  .cal-month-name {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #555;
    margin-bottom: 0.35rem;
    text-align: center;
    cursor: pointer;
  }
  .cal-month-name:hover { color: #D4881A; }

  /* Shared 7-column grid */
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 2px;
  }

  /* Day-of-week header */
  .cal-dh {
    font-size: 0.6rem;
    text-align: center;
    color: #888;
    font-weight: 600;
    padding-bottom: 2px;
  }

  .cal-dh-full {
    font-size: 0.72rem;
    font-weight: 700;
    text-align: center;
    color: #555;
    padding: 0.4rem 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid #E8D9B8;
  }

  /* ── Mini day cell ──────────────────────────────────────────────── */
  .cal-cell-mini {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    padding: 2px 1px;
    border-radius: 4px;
    min-height: 32px;
  }

  .cal-cell-mini:hover { background: #FDE9C0; }

  .cal-num {
    font-size: 0.62rem;
    color: #555;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  /* ── Full day cell ──────────────────────────────────────────────── */
  .cal-grid-full { gap: 3px; }

  .cal-cell-full {
    min-height: 80px;
    padding: 0.35rem 0.4rem;
    border: 1px solid #E8D9B8;
    border-radius: 4px;
    background: #fff;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cal-cell-full:hover { background: #FFF8EE; }

  .cal-num-full {
    font-size: 0.8rem;
    color: #555;
    font-weight: 500;
    line-height: 1;
  }

  /* ── Dot containers ─────────────────────────────────────────────── */
  .cal-dots-mini {
    display: flex;
    flex-wrap: wrap;
    gap: 1px;
    justify-content: center;
    width: 100%;
  }

  .cal-dots-full {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
  }

  /* ── Dots ───────────────────────────────────────────────────────── */
  .cal-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    line-height: 1;
    flex-shrink: 0;
    transition: filter 0.12s;
    /* mini size by default */
    width: 9px;
    height: 9px;
    font-size: 0.42rem;
  }

  .cal-dots-full .cal-dot {
    width: 22px;
    height: 22px;
    font-size: 0.72rem;
    border-radius: 4px;
  }

  .cal-dot:hover { filter: brightness(1.2); }

  /* ── Empty / dimmed cells ───────────────────────────────────────── */
  .cal-pad   { visibility: hidden; }
  .cal-future { opacity: 0.22; pointer-events: none; }
  .cal-grey   { opacity: 0.35; }

  /* ── Full month wrapper ─────────────────────────────────────────── */
  .cal-month-full { width: 100%; }

  /* ── Legend ─────────────────────────────────────────────────────── */
  .cal-legend {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.85rem;
    font-size: 0.78rem;
    color: #555;
    align-items: center;
  }

  .cal-swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
    margin-right: 3px;
    vertical-align: middle;
  }

  .cal-legend-hint { font-style: italic; color: #888; }

  /* ── Date range trigger button ──────────────────────────────────────── */
  .dp-trigger-btn {
    min-width: 200px;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
