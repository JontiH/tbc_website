---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const currentPath = "/members/hive-data";

const WORKER_URL = import.meta.env.HIVE_WORKER_URL ?? "https://tbc-sheets-worker.YOUR_SUBDOMAIN.workers.dev";
---

<Base
  title="Hive Data"
  description="Browse and filter hive visit records for TBC colonies."
>
  <Nav slot="nav" currentPath={currentPath} />

  <div class="page-header">
    <div class="container page-header-content">
      <h1>Hive Data</h1>
      <p>Colony visit records, health status, mite counts, and treatments — filterable by location and colony.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">

      <!-- Filters -->
      <div class="filters" id="filters">
        <div class="filter-group">
          <label for="filter-location">Location</label>
          <select id="filter-location">
            <option value="">All Locations</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-colony">Colony</label>
          <select id="filter-colony">
            <option value="">All Colonies</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-date-from">From</label>
          <input type="date" id="filter-date-from" />
        </div>
        <div class="filter-group">
          <label for="filter-date-to">To</label>
          <input type="date" id="filter-date-to" />
        </div>
        <div class="filter-group">
          <label for="filter-status">Status</label>
          <select id="filter-status">
            <option value="">All Statuses</option>
            <option value="strong">Strong 👍</option>
            <option value="neutral">Neutral 👋</option>
            <option value="weak">Weak 👎</option>
          </select>
        </div>
        <div class="filter-group" style="justify-content: flex-end;">
          <button id="filter-reset" class="btn btn-outline-dark" style="align-self:flex-end;">Reset</button>
        </div>
      </div>

      <!-- Loading / error states -->
      <div id="loading-state" class="loading">Loading hive data...</div>
      <div id="error-state" class="error-msg" style="display:none;"></div>

      <!-- Charts area -->
      <div id="charts-area" style="display:none;">

        <!-- Visit Calendar -->
        <div class="chart-container" style="margin-bottom: 1.25rem;">
          <div class="cal-nav-header">
            <span class="chart-title" style="margin:0;">Hive Visit Calendar</span>
            <div class="cal-controls">
              <button id="cal-prev" class="btn btn-outline-dark btn-sm" aria-label="Previous">&#8249;</button>
              <span id="cal-label" class="cal-label"></span>
              <button id="cal-next" class="btn btn-outline-dark btn-sm" aria-label="Next">&#8250;</button>
              <button id="cal-toggle" class="btn btn-outline-dark btn-sm">Monthly View</button>
            </div>
          </div>
          <div id="calendar-body"></div>
          <div class="cal-legend">
            <span><span class="cal-swatch" style="background:#2E7D32;"></span> Strong</span>
            <span><span class="cal-swatch" style="background:#F57F17;"></span> Neutral</span>
            <span><span class="cal-swatch" style="background:#C62828;"></span> Weak</span>
            <span class="cal-legend-hint">Click a square to jump to that visit</span>
          </div>
        </div>

        <!-- Mite chart -->
        <div id="mite-chart-wrap" class="chart-container" style="display:none; margin-bottom: 0;">
          <div class="chart-title">Mite Count Over Time</div>
          <canvas id="chart-mites" height="90"></canvas>
        </div>

      </div>

      <!-- Summary row -->
      <div id="summary-row" style="display:none;" class="summary-row">
        <div class="summary-stat">
          <span id="stat-visits">0</span>
          <span>Visits shown</span>
        </div>
        <div class="summary-stat">
          <span id="stat-colonies">0</span>
          <span>Colonies</span>
        </div>
        <div class="summary-stat">
          <span id="stat-locations">0</span>
          <span>Locations</span>
        </div>
        <div class="summary-stat">
          <span id="stat-mite-avg">—</span>
          <span>Avg mite count</span>
        </div>
      </div>

      <!-- Table -->
      <div id="table-area" style="display:none;">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Location</th>
                <th>Colony</th>
                <th>Status</th>
                <th>Mite Count</th>
                <th>Treatment</th>
                <th>Feed</th>
                <th>Comments</th>
              </tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
        </div>
        <p id="table-empty" style="display:none; text-align:center; padding:2rem; color:var(--charcoal-mid);">
          No records match your filters.
        </p>
      </div>

    </div>
  </section>

  <!-- Floating tooltip (outside container to avoid overflow clipping) -->
  <div id="cal-tooltip" role="tooltip" aria-hidden="true"></div>

  <Footer slot="footer" />
</Base>

<script define:vars={{ WORKER_URL }}>
  const COL = {
    LOCATION:  "location",
    COLONY:    "colony",
    STATUS:    "status",
    MITE:      "mite_count",
    TREATMENT: "treatment",
    FEED:      "feed",
    COMMENTS:  "comments",
    DATE:      "date",
  };

  // ── Status helpers ────────────────────────────────────────────────────
  function normaliseStatus(raw) {
    if (!raw) return "neutral";
    const s = raw.toLowerCase();
    if (s.includes("strong")) return "strong";
    if (s.includes("weak"))   return "weak";
    return "neutral";
  }

  function statusLabel(status) {
    return { strong: "Strong 👍", neutral: "Neutral 👋", weak: "Weak 👎" }[status] ?? "Neutral 👋";
  }

  function statusBadge(status) {
    const map = {
      strong:  ["badge-good", "Strong 👍"],
      neutral: ["badge-mid",  "Neutral 👋"],
      weak:    ["badge-bad",  "Weak 👎"],
    };
    const [cls, label] = map[status] ?? map.neutral;
    return `<span class="badge ${cls}">${label}</span>`;
  }

  const STATUS_COL = { strong: "#2E7D32", neutral: "#F57F17", weak: "#C62828" };

  // ── Date helpers ──────────────────────────────────────────────────────
  function parseDate(val) {
    if (!val) return null;
    const dmy = val.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (dmy) {
      const d = new Date(parseInt(dmy[3]), parseInt(dmy[2]) - 1, parseInt(dmy[1]));
      return isNaN(d.getTime()) ? null : d;
    }
    const d = new Date(val);
    if (isNaN(d.getTime()) || d.getFullYear() < 2000) return null;
    return d;
  }

  function fmtDate(d, opts) {
    if (!d) return "—";
    return d.toLocaleDateString("en-CA", opts ?? { year: "numeric", month: "short", day: "numeric" });
  }

  function dateKey(d) {
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
  }

  // ── State ─────────────────────────────────────────────────────────────
  let allRows  = [];
  let charts   = {};
  let calView  = "year";
  let calYear  = new Date().getFullYear();
  let calMonth = new Date().getMonth();

  // ── DOM refs ──────────────────────────────────────────────────────────
  const $ = id => document.getElementById(id);
  const selLocation = $("filter-location");
  const selColony   = $("filter-colony");
  const inpFrom     = $("filter-date-from");
  const inpTo       = $("filter-date-to");
  const selStatus   = $("filter-status");
  const btnReset    = $("filter-reset");
  const loadingEl   = $("loading-state");
  const errorEl     = $("error-state");
  const chartsArea  = $("charts-area");
  const miteWrap    = $("mite-chart-wrap");
  const summaryRow  = $("summary-row");
  const tableArea   = $("table-area");
  const tableBody   = $("table-body");
  const tableEmpty  = $("table-empty");
  const tooltip     = $("cal-tooltip");

  // ── Tooltip ───────────────────────────────────────────────────────────
  function showTooltip(evt, lines) {
    tooltip.innerHTML = lines.map(l => `<div>${l}</div>`).join("");
    tooltip.style.display = "block";
    positionTooltip(evt);
  }

  function positionTooltip(evt) {
    const pad = 12;
    const tw  = tooltip.offsetWidth;
    const th  = tooltip.offsetHeight;
    let   x   = evt.clientX + pad;
    let   y   = evt.clientY + pad;
    if (x + tw > window.innerWidth  - 8) x = evt.clientX - tw - pad;
    if (y + th > window.innerHeight - 8) y = evt.clientY - th - pad;
    tooltip.style.left = x + "px";
    tooltip.style.top  = y + "px";
  }

  function hideTooltip() {
    tooltip.style.display = "none";
  }

  // ── Fetch ─────────────────────────────────────────────────────────────
  async function fetchData() {
    try {
      const res = await fetch(`${WORKER_URL}/hive-data`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const json = await res.json();
      allRows = (json.rows ?? []).map((r, i) => ({ ...r, _id: i }));
      init();
    } catch (err) {
      loadingEl.style.display = "none";
      errorEl.style.display   = "block";
      errorEl.textContent     = `Failed to load hive data: ${err.message}. Make sure the Worker is deployed and HIVE_WORKER_URL is configured.`;
    }
  }

  // ── Init ─────────────────────────────────────────────────────────────
  function init() {
    loadingEl.style.display = "none";

    const locations = [...new Set(allRows.map(r => r[COL.LOCATION]).filter(Boolean))].sort();
    locations.forEach(loc => {
      const opt = document.createElement("option");
      opt.value = loc;
      opt.textContent = loc;
      selLocation.appendChild(opt);
    });

    const year = new Date().getFullYear();
    inpFrom.value = `${year}-01-01`;
    inpTo.value   = `${year}-12-31`;

    render();

    chartsArea.style.display = "block";
    summaryRow.style.display = "flex";
    tableArea.style.display  = "block";
  }

  // ── Filtering ─────────────────────────────────────────────────────────
  function getFiltered() {
    const loc      = selLocation.value;
    const colony   = selColony.value;
    const from     = inpFrom.value ? new Date(inpFrom.value)             : null;
    const to       = inpTo.value   ? new Date(inpTo.value + "T23:59:59") : null;
    const statFilt = selStatus.value;

    return allRows.filter(r => {
      if (loc    && r[COL.LOCATION] !== loc)    return false;
      if (colony && r[COL.COLONY]   !== colony) return false;
      if (statFilt && normaliseStatus(r[COL.STATUS]) !== statFilt) return false;
      const d = parseDate(r[COL.DATE]);
      if (from && d && d < from) return false;
      if (to   && d && d > to)   return false;
      return true;
    });
  }

  function updateCalFromFilter() {
    const from = inpFrom.value ? new Date(inpFrom.value) : null;
    const to   = inpTo.value   ? new Date(inpTo.value)   : null;

    if (from && to) {
      const days = (to - from) / 86400000;
      if (days <= 45) {
        calView  = "month";
        calYear  = from.getFullYear();
        calMonth = from.getMonth();
      } else {
        calView = "year";
        calYear = from.getFullYear();
      }
    } else if (from) {
      calYear = from.getFullYear();
    } else {
      calView  = "year";
      calYear  = new Date().getFullYear();
      calMonth = new Date().getMonth();
    }
  }

  // ── Colony dropdown ───────────────────────────────────────────────────
  selLocation.addEventListener("change", () => {
    const loc = selLocation.value;
    const prevColony = selColony.value;
    selColony.innerHTML = "<option value=''>All Colonies</option>";
    const colonies = [...new Set(
      allRows
        .filter(r => !loc || r[COL.LOCATION] === loc)
        .map(r => r[COL.COLONY])
        .filter(Boolean)
    )].sort();
    colonies.forEach(c => {
      const opt = document.createElement("option");
      opt.value = c;
      opt.textContent = `Colony ${c}`;
      if (c === prevColony) opt.selected = true;
      selColony.appendChild(opt);
    });
    render();
  });

  selColony.addEventListener("change", render);
  inpFrom.addEventListener("change",   () => { updateCalFromFilter(); render(); });
  inpTo.addEventListener("change",     () => { updateCalFromFilter(); render(); });
  selStatus.addEventListener("change", render);

  btnReset.addEventListener("click", () => {
    selLocation.value = "";
    selColony.value   = "";
    inpFrom.value     = "";
    inpTo.value       = "";
    selStatus.value   = "";
    calView  = "year";
    calYear  = new Date().getFullYear();
    calMonth = new Date().getMonth();
    selLocation.dispatchEvent(new Event("change"));
  });

  // ── Calendar nav ──────────────────────────────────────────────────────
  $("cal-prev").addEventListener("click", () => {
    if (calView === "year") { calYear--; }
    else { calMonth--; if (calMonth < 0)  { calMonth = 11; calYear--; } }
    renderCalendar(getFiltered());
  });
  $("cal-next").addEventListener("click", () => {
    if (calView === "year") { calYear++; }
    else { calMonth++; if (calMonth > 11) { calMonth = 0;  calYear++; } }
    renderCalendar(getFiltered());
  });
  $("cal-toggle").addEventListener("click", () => {
    calView  = calView === "year" ? "month" : "year";
    if (calView === "month") calMonth = new Date().getMonth();
    renderCalendar(getFiltered());
  });

  // ── Scroll + flash table rows ─────────────────────────────────────────
  function scrollToRows(ids) {
    const trs = ids.map(id => document.getElementById("entry-" + id)).filter(Boolean);
    if (!trs.length) return;
    trs[0].scrollIntoView({ behavior: "smooth", block: "center" });
    trs.forEach(tr => {
      tr.classList.remove("row-highlight");
      void tr.offsetWidth;
      tr.classList.add("row-highlight");
    });
  }

  // ── Main render ───────────────────────────────────────────────────────
  function render() {
    const rows = getFiltered();
    renderSummary(rows);
    renderTable(rows);
    renderCalendar(rows);
    renderMiteChart(rows);
  }

  // ── Summary ───────────────────────────────────────────────────────────
  function renderSummary(rows) {
    $("stat-visits").textContent    = rows.length;
    $("stat-colonies").textContent  = new Set(rows.map(r => r[COL.COLONY])).size;
    $("stat-locations").textContent = new Set(rows.map(r => r[COL.LOCATION])).size;
    const mites = rows.map(r => parseFloat(r[COL.MITE])).filter(n => !isNaN(n));
    $("stat-mite-avg").textContent = mites.length
      ? (mites.reduce((a, b) => a + b, 0) / mites.length).toFixed(1)
      : "—";
  }

  // ── Table ─────────────────────────────────────────────────────────────
  function renderTable(rows) {
    tableBody.innerHTML = "";
    if (rows.length === 0) { tableEmpty.style.display = "block"; return; }
    tableEmpty.style.display = "none";

    const sorted = [...rows].sort((a, b) => {
      const da = parseDate(a[COL.DATE]);
      const db = parseDate(b[COL.DATE]);
      if (!da && !db) return 0;
      if (!da) return 1;
      if (!db) return -1;
      return db - da;
    });

    sorted.forEach(r => {
      const status = normaliseStatus(r[COL.STATUS]);
      const tr = document.createElement("tr");
      tr.id = "entry-" + r._id;
      tr.innerHTML = `
        <td>${fmtDate(parseDate(r[COL.DATE]))}</td>
        <td>${r[COL.LOCATION] ?? "—"}</td>
        <td>${r[COL.COLONY] ? `Colony ${r[COL.COLONY]}` : "—"}</td>
        <td>${statusBadge(status)}</td>
        <td>${r[COL.MITE] ?? "—"}</td>
        <td>${r[COL.TREATMENT] ?? "—"}</td>
        <td>${r[COL.FEED] ?? "—"}</td>
        <td style="max-width:240px; white-space:pre-wrap; font-size:0.85rem;">${r[COL.COMMENTS] ?? ""}</td>
      `;
      tableBody.appendChild(tr);
    });
  }

  // ── Calendar ──────────────────────────────────────────────────────────

  // visitMap: "YYYY-MM-DD" → { strong:[{_id,colony,location},...], neutral:[...], weak:[...] }
  function buildVisitMap(rows) {
    const map = new Map();
    rows.forEach(r => {
      const d = parseDate(r[COL.DATE]);
      if (!d) return;
      const key = dateKey(d);
      if (!map.has(key)) map.set(key, { strong: [], neutral: [], weak: [] });
      const norm = normaliseStatus(r[COL.STATUS]);
      map.get(key)[norm].push({
        _id:      r._id,
        colony:   r[COL.COLONY]   ?? "?",
        location: r[COL.LOCATION] ?? "?",
      });
    });
    return map;
  }

  const WEEK_HEADS_SHORT = ["M", "T", "W", "T", "F", "S", "S"];
  const WEEK_HEADS_LONG  = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];

  // Build a dot element (returns an HTMLElement)
  function makeDot(status, visits, dateStr) {
    const span = document.createElement("span");
    span.className = "cal-dot";
    span.style.background = STATUS_COL[status];
    const count = visits.length;
    if (count > 1) span.textContent = String(count);

    // Tooltip lines: date header + one line per visit
    const tipLines = [
      `<strong>${dateStr}</strong>`,
      ...visits.map(v => `Colony ${v.colony} @ ${v.location} — ${statusLabel(status)}`),
    ];

    span.addEventListener("mouseenter", evt => showTooltip(evt, tipLines));
    span.addEventListener("mousemove",  evt => positionTooltip(evt));
    span.addEventListener("mouseleave", hideTooltip);
    span.addEventListener("click", e => {
      e.stopPropagation();
      hideTooltip();
      scrollToRows(visits.map(v => v._id));
    });
    return span;
  }

  // Build a day cell element for the mini (year) calendar
  function makeMiniCell(day, visits, isFuture, inRange, dateStr) {
    const cell = document.createElement("div");
    cell.className = "cal-cell-mini" + (isFuture ? " cal-future" : !inRange ? " cal-grey" : "");

    const num = document.createElement("span");
    num.className = "cal-num";
    num.textContent = String(day);
    cell.appendChild(num);

    if (visits && inRange && !isFuture) {
      const dotsWrap = document.createElement("div");
      dotsWrap.className = "cal-dots-mini";
      for (const [status, list] of Object.entries(visits)) {
        if (!list.length) continue;
        dotsWrap.appendChild(makeDot(status, list, dateStr));
      }
      cell.appendChild(dotsWrap);
    }
    return cell;
  }

  // Build a day cell element for the full (month) calendar
  function makeFullCell(day, visits, isFuture, inRange, dateStr) {
    const cell = document.createElement("div");
    cell.className = "cal-cell-full" + (isFuture ? " cal-future" : !inRange ? " cal-grey" : "");

    const num = document.createElement("span");
    num.className = "cal-num-full";
    num.textContent = String(day);
    cell.appendChild(num);

    if (visits && inRange && !isFuture) {
      const dotsWrap = document.createElement("div");
      dotsWrap.className = "cal-dots-full";
      for (const [status, list] of Object.entries(visits)) {
        if (!list.length) continue;
        dotsWrap.appendChild(makeDot(status, list, dateStr));
      }
      cell.appendChild(dotsWrap);
    }
    return cell;
  }

  function buildMonthMini(year, month, visitMap, today, from, to) {
    const wrap = document.createElement("div");
    wrap.className = "cal-month";

    // Month name header
    const header = document.createElement("div");
    header.className = "cal-month-name";
    header.textContent = new Date(year, month).toLocaleDateString("en-CA", { month: "short" });
    wrap.appendChild(header);

    // 7-column grid
    const grid = document.createElement("div");
    grid.className = "cal-grid";

    // Day-of-week headers
    WEEK_HEADS_SHORT.forEach(h => {
      const dh = document.createElement("div");
      dh.className = "cal-dh";
      dh.textContent = h;
      grid.appendChild(dh);
    });

    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const offset      = (new Date(year, month, 1).getDay() + 6) % 7; // Mon=0

    for (let i = 0; i < offset; i++) {
      const pad = document.createElement("div");
      pad.className = "cal-cell-mini cal-pad";
      grid.appendChild(pad);
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const date    = new Date(year, month, day);
      const key     = dateKey(date);
      const visits  = visitMap.get(key) ?? null;
      const future  = date > today;
      const inRange = (!from || date >= from) && (!to || date <= to);
      const dateStr = fmtDate(date);
      grid.appendChild(makeMiniCell(day, visits, future, inRange, dateStr));
    }

    wrap.appendChild(grid);
    return wrap;
  }

  function buildMonthFull(year, month, visitMap, today, from, to) {
    const wrap = document.createElement("div");
    wrap.className = "cal-month-full";

    // 7-column grid
    const grid = document.createElement("div");
    grid.className = "cal-grid cal-grid-full";

    WEEK_HEADS_LONG.forEach(h => {
      const dh = document.createElement("div");
      dh.className = "cal-dh cal-dh-full";
      dh.textContent = h;
      grid.appendChild(dh);
    });

    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const offset      = (new Date(year, month, 1).getDay() + 6) % 7;

    for (let i = 0; i < offset; i++) {
      const pad = document.createElement("div");
      pad.className = "cal-cell-full cal-pad";
      grid.appendChild(pad);
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const date    = new Date(year, month, day);
      const key     = dateKey(date);
      const visits  = visitMap.get(key) ?? null;
      const future  = date > today;
      const inRange = (!from || date >= from) && (!to || date <= to);
      const dateStr = fmtDate(date);
      grid.appendChild(makeFullCell(day, visits, future, inRange, dateStr));
    }

    wrap.appendChild(grid);
    return wrap;
  }

  function renderCalendar(rows) {
    const visitMap  = buildVisitMap(rows);
    const today     = new Date();
    const from      = inpFrom.value ? new Date(inpFrom.value)             : null;
    const to        = inpTo.value   ? new Date(inpTo.value + "T23:59:59") : null;
    const body      = $("calendar-body");
    const labelEl   = $("cal-label");
    const toggleBtn = $("cal-toggle");

    body.innerHTML = "";

    if (calView === "year") {
      labelEl.textContent   = String(calYear);
      toggleBtn.textContent = "Monthly View";

      const maxMonth = (calYear === today.getFullYear()) ? today.getMonth() : 11;
      const yearGrid = document.createElement("div");
      yearGrid.className = "cal-year";

      for (let m = 0; m <= maxMonth; m++) {
        yearGrid.appendChild(buildMonthMini(calYear, m, visitMap, today, from, to));
      }
      body.appendChild(yearGrid);

    } else {
      const label = new Date(calYear, calMonth).toLocaleDateString("en-CA", { month: "long", year: "numeric" });
      labelEl.textContent   = label;
      toggleBtn.textContent = "Yearly View";
      body.appendChild(buildMonthFull(calYear, calMonth, visitMap, today, from, to));
    }
  }

  // ── Mite chart ────────────────────────────────────────────────────────
  async function renderMiteChart(rows) {
    const { Chart, registerables } = await import("https://cdn.jsdelivr.net/npm/chart.js@4/+esm");
    Chart.register(...registerables);

    const mitePoints = rows
      .map(r => {
        const d   = parseDate(r[COL.DATE]);
        const val = parseFloat(r[COL.MITE]);
        if (!d || isNaN(val)) return null;
        return {
          x: d.getTime(), y: val, _id: r._id,
          dateStr: fmtDate(d), colony: r[COL.COLONY] ?? "?", location: r[COL.LOCATION] ?? "?",
        };
      })
      .filter(Boolean)
      .sort((a, b) => a.x - b.x);

    if (mitePoints.length > 0) {
      miteWrap.style.display = "block";
      if (charts.mites) charts.mites.destroy();
      charts.mites = new Chart($("chart-mites"), {
        type: "scatter",
        data: {
          datasets: [{
            data: mitePoints,
            backgroundColor: "rgba(198,40,40,0.75)",
            borderColor: "#C62828",
            pointRadius: 6, pointHoverRadius: 8,
          }],
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                title: () => "",
                label: ctx => {
                  const p = ctx.raw;
                  return [p.dateStr, `Colony ${p.colony} @ ${p.location}`, `Mite count: ${p.y}`];
                },
              },
            },
          },
          scales: {
            x: {
              type: "linear", grid: { display: false },
              ticks: {
                maxTicksLimit: 8,
                callback: v => new Date(v).toLocaleDateString("en-CA", { month: "short", day: "numeric", year: "2-digit" }),
              },
            },
            y: {
              beginAtZero: true,
              title: { display: true, text: "Mites per 100 bees" },
              grid: { color: "rgba(0,0,0,0.06)" },
            },
          },
          onClick: (evt, elements) => {
            if (!elements.length) return;
            scrollToRows([mitePoints[elements[0].index]._id]);
          },
          onHover: (evt, elements) => {
            evt.native.target.style.cursor = elements.length ? "pointer" : "default";
          },
        },
      });
    } else {
      miteWrap.style.display = "none";
      if (charts.mites) { charts.mites.destroy(); charts.mites = null; }
    }
  }

  // ── Boot ──────────────────────────────────────────────────────────────
  fetchData();
</script>

