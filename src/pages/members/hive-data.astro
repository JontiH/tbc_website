  #dp-status { font-size: 0.75rem; color: #555; flex: 1; }

  /* ── Year/month/day dropdown ────────────────────────────────────────── */
  .dp-dd-header {
    text-align: center;
    font-weight: 700;
    font-size: 0.85rem;
