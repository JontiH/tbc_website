---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const currentPath = "/members/hive-data";

// The Worker URL — set via env var at build time, fallback for local dev
const WORKER_URL = import.meta.env.HIVE_WORKER_URL ?? "https://tbc-sheets-worker.YOUR_SUBDOMAIN.workers.dev";
---

<Base
  title="Hive Data"
  description="Browse and filter hive visit records for TBC colonies."
>
  <Nav slot="nav" currentPath={currentPath} />

  <div class="page-header">
    <div class="container page-header-content">
      <h1>Hive Data</h1>
      <p>Colony visit records, health status, mite counts, and treatments — filterable by location and colony.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">

      <!-- Filters -->
      <div class="filters" id="filters">
        <div class="filter-group">
          <label for="filter-location">Location</label>
          <select id="filter-location">
            <option value="">All Locations</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-colony">Colony</label>
          <select id="filter-colony">
            <option value="">All Colonies</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-date-from">From</label>
          <input type="date" id="filter-date-from" />
        </div>
        <div class="filter-group">
          <label for="filter-date-to">To</label>
          <input type="date" id="filter-date-to" />
        </div>
        <div class="filter-group">
          <label for="filter-status">Status</label>
          <select id="filter-status">
            <option value="">All Statuses</option>
            <option value="strong">Strong 👍</option>
            <option value="neutral">Neutral 👋</option>
            <option value="weak">Weak 👎</option>
          </select>
        </div>
        <div class="filter-group" style="justify-content: flex-end;">
          <button id="filter-reset" class="btn btn-outline-dark" style="align-self:flex-end;">Reset</button>
        </div>
      </div>

      <!-- Loading / error states -->
      <div id="loading-state" class="loading">Loading hive data...</div>
      <div id="error-state" class="error-msg" style="display:none;"></div>

      <!-- Charts -->
      <div id="charts-area" style="display:none;">
        <div class="chart-container" style="margin-bottom: 1.25rem;">
          <div class="chart-title">Hive Status Over Time</div>
          <canvas id="chart-status-time" height="90"></canvas>
        </div>
        <div id="mite-chart-wrap" class="chart-container" style="display:none; margin-bottom: 0;">
          <div class="chart-title">Mite Count Over Time</div>
          <canvas id="chart-mites" height="90"></canvas>
        </div>
      </div>

      <!-- Summary row -->
      <div id="summary-row" style="display:none;" class="summary-row">
        <div class="summary-stat">
          <span id="stat-visits">0</span>
          <span>Visits shown</span>
        </div>
        <div class="summary-stat">
          <span id="stat-colonies">0</span>
          <span>Colonies</span>
        </div>
        <div class="summary-stat">
          <span id="stat-locations">0</span>
          <span>Locations</span>
        </div>
        <div class="summary-stat">
          <span id="stat-mite-avg">—</span>
          <span>Avg mite count</span>
        </div>
      </div>

      <!-- Table -->
      <div id="table-area" style="display:none;">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Date</th>
                <th>Location</th>
                <th>Colony</th>
                <th>Status</th>
                <th>Mite Count</th>
                <th>Treatment</th>
                <th>Feed</th>
                <th>Comments</th>
              </tr>
            </thead>
            <tbody id="table-body"></tbody>
          </table>
        </div>
        <p id="table-empty" style="display:none; text-align:center; padding:2rem; color:var(--charcoal-mid);">
          No records match your filters.
        </p>
      </div>

    </div>
  </section>

  <Footer slot="footer" />
</Base>

<script define:vars={{ WORKER_URL }}>
  const COL = {
    LOCATION:  "location",
    COLONY:    "colony",
    STATUS:    "status",
    MITE:      "mite_count",
    TREATMENT: "treatment",
    FEED:      "feed",
    COMMENTS:  "comments",
    DATE:      "date",
  };

  // ── Status normalisation ─────────────────────────────────────────────
  // Sheet values: "weak👎"  "neutral 👋"  "strong 👍"
  function normaliseStatus(raw) {
    if (!raw) return "unknown";
    const s = raw.toLowerCase();
    if (s.includes("strong")) return "strong";
    if (s.includes("neutral")) return "neutral";
    if (s.includes("weak")) return "weak";
    return "unknown";
  }

  function statusScore(status) {
    return { strong: 3, neutral: 2, weak: 1 }[status] ?? null;
  }

  function statusLabel(status) {
    return { strong: "Strong 👍", neutral: "Neutral 👋", weak: "Weak 👎", unknown: "Unknown" }[status] ?? "Unknown";
  }

  function statusBadge(status) {
    const map = {
      strong:  ["badge-good", "Strong 👍"],
      neutral: ["badge-mid",  "Neutral 👋"],
      weak:    ["badge-bad",  "Weak 👎"],
      unknown: ["badge-unknown", "Unknown"],
    };
    const [cls, label] = map[status] ?? map.unknown;
    return `<span class="badge ${cls}">${label}</span>`;
  }

  // ── Date helpers ─────────────────────────────────────────────────────
  function parseDate(val) {
    if (!val) return null;
    // Handle DD/MM/YYYY from Google Sheets
    const dmy = val.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
    if (dmy) {
      const d = new Date(parseInt(dmy[3]), parseInt(dmy[2]) - 1, parseInt(dmy[1]));
      return isNaN(d.getTime()) ? null : d;
    }
    const d = new Date(val);
    return isNaN(d.getTime()) ? null : d;
  }

  function fmtDate(d) {
    if (!d) return "—";
    return d.toLocaleDateString("en-CA", { year: "numeric", month: "short", day: "numeric" });
  }

  // ── State ────────────────────────────────────────────────────────────
  let allRows = [];
  let charts  = {};

  // ── DOM refs ─────────────────────────────────────────────────────────
  const $ = id => document.getElementById(id);
  const selLocation  = $("filter-location");
  const selColony    = $("filter-colony");
  const inpFrom      = $("filter-date-from");
  const inpTo        = $("filter-date-to");
  const selStatus    = $("filter-status");
  const btnReset     = $("filter-reset");
  const loadingEl    = $("loading-state");
  const errorEl      = $("error-state");
  const chartsArea   = $("charts-area");
  const miteWrap     = $("mite-chart-wrap");
  const summaryRow   = $("summary-row");
  const tableArea    = $("table-area");
  const tableBody    = $("table-body");
  const tableEmpty   = $("table-empty");

  // ── Fetch ────────────────────────────────────────────────────────────
  async function fetchData() {
    try {
      const res = await fetch(`${WORKER_URL}/hive-data`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const json = await res.json();
      // Assign a stable _id to each row for chart→table linking
      allRows = (json.rows ?? []).map((r, i) => ({ ...r, _id: i }));
      init();
    } catch (err) {
      loadingEl.style.display = "none";
      errorEl.style.display   = "block";
      errorEl.textContent     = `Failed to load hive data: ${err.message}. Make sure the Worker is deployed and the HIVE_WORKER_URL is configured.`;
    }
  }

  // ── Initialise filters & render ──────────────────────────────────────
  function init() {
    loadingEl.style.display = "none";

    // Populate location dropdown
    const locations = [...new Set(allRows.map(r => r[COL.LOCATION]).filter(Boolean))].sort();
    locations.forEach(loc => {
      const opt = document.createElement("option");
      opt.value = loc;
      opt.textContent = loc;
      selLocation.appendChild(opt);
    });

    // Default to current calendar year
    const year = new Date().getFullYear();
    inpFrom.value = `${year}-01-01`;
    inpTo.value   = `${year}-12-31`;

    render();

    chartsArea.style.display = "block";
    summaryRow.style.display = "flex";
    tableArea.style.display  = "block";
  }

  // ── Filtering ────────────────────────────────────────────────────────
  function getFiltered() {
    const loc      = selLocation.value;
    const colony   = selColony.value;
    const from     = inpFrom.value ? new Date(inpFrom.value)                 : null;
    const to       = inpTo.value   ? new Date(inpTo.value + "T23:59:59")     : null;
    const statFilt = selStatus.value;

    return allRows.filter(r => {
      if (loc    && r[COL.LOCATION] !== loc)    return false;
      if (colony && r[COL.COLONY]   !== colony) return false;
      if (statFilt) {
        if (normaliseStatus(r[COL.STATUS]) !== statFilt) return false;
      }
      const d = parseDate(r[COL.DATE]);
      if (from && d && d < from) return false;
      if (to   && d && d > to)   return false;
      return true;
    });
  }

  // ── Colony dropdown updates based on location selection ─────────────
  selLocation.addEventListener("change", () => {
    const loc = selLocation.value;
    const prevColony = selColony.value;
    selColony.innerHTML = "<option value=''>All Colonies</option>";
    const colonies = [...new Set(
      allRows
        .filter(r => !loc || r[COL.LOCATION] === loc)
        .map(r => r[COL.COLONY])
        .filter(Boolean)
    )].sort();
    colonies.forEach(c => {
      const opt = document.createElement("option");
      opt.value = c;
      opt.textContent = `Colony ${c}`;
      if (c === prevColony) opt.selected = true;
      selColony.appendChild(opt);
    });
    render();
  });

  selColony.addEventListener("change",  render);
  inpFrom.addEventListener("change",    render);
  inpTo.addEventListener("change",      render);
  selStatus.addEventListener("change",  render);

  btnReset.addEventListener("click", () => {
    selLocation.value = "";
    selColony.value   = "";
    inpFrom.value     = "";
    inpTo.value       = "";
    selStatus.value   = "";
    selLocation.dispatchEvent(new Event("change"));
  });

  // ── Scroll to table row and flash it ────────────────────────────────
  function scrollToRow(_id) {
    const tr = document.getElementById("entry-" + _id);
    if (!tr) return;
    tr.scrollIntoView({ behavior: "smooth", block: "center" });
    tr.classList.remove("row-highlight");
    // Force reflow so removing+re-adding the class re-triggers animation
    void tr.offsetWidth;
    tr.classList.add("row-highlight");
  }

  // ── Main render ──────────────────────────────────────────────────────
  function render() {
    const rows = getFiltered();
    renderSummary(rows);
    // renderTable returns the sorted order so renderCharts can reference row IDs
    const sortedRows = renderTable(rows);
    renderCharts(rows, sortedRows);
  }

  // ── Summary ──────────────────────────────────────────────────────────
  function renderSummary(rows) {
    $("stat-visits").textContent    = rows.length;
    $("stat-colonies").textContent  = new Set(rows.map(r => r[COL.COLONY])).size;
    $("stat-locations").textContent = new Set(rows.map(r => r[COL.LOCATION])).size;

    const mites = rows.map(r => parseFloat(r[COL.MITE])).filter(n => !isNaN(n));
    $("stat-mite-avg").textContent = mites.length
      ? (mites.reduce((a, b) => a + b, 0) / mites.length).toFixed(1)
      : "—";
  }

  // ── Table — returns sorted rows (newest first) ───────────────────────
  function renderTable(rows) {
    tableBody.innerHTML = "";

    if (rows.length === 0) {
      tableEmpty.style.display = "block";
      return [];
    }
    tableEmpty.style.display = "none";

    // Sort newest first
    const sorted = [...rows].sort((a, b) => {
      const da = parseDate(a[COL.DATE]);
      const db = parseDate(b[COL.DATE]);
      if (!da && !db) return 0;
      if (!da) return 1;
      if (!db) return -1;
      return db - da;
    });

    sorted.forEach(r => {
      const status = normaliseStatus(r[COL.STATUS]);
      const tr = document.createElement("tr");
      tr.id = "entry-" + r._id;
      tr.innerHTML = `
        <td>${fmtDate(parseDate(r[COL.DATE]))}</td>
        <td>${r[COL.LOCATION] ?? "—"}</td>
        <td>${r[COL.COLONY] ? `Colony ${r[COL.COLONY]}` : "—"}</td>
        <td>${statusBadge(status)}</td>
        <td>${r[COL.MITE] ?? "—"}</td>
        <td>${r[COL.TREATMENT] ?? "—"}</td>
        <td>${r[COL.FEED] ?? "—"}</td>
        <td style="max-width:240px; white-space:pre-wrap; font-size:0.85rem;">${r[COL.COMMENTS] ?? ""}</td>
      `;
      tableBody.appendChild(tr);
    });

    return sorted;
  }

  // ── Charts ───────────────────────────────────────────────────────────
  async function renderCharts(rows, sortedRows) {
    const { Chart, registerables } = await import("https://cdn.jsdelivr.net/npm/chart.js@4/+esm");
    Chart.register(...registerables);

    // ── Status Over Time (scatter, score 1–3) ────────────────────────
    // Points sorted ascending by date
    const statusPoints = rows
      .map(r => {
        const d     = parseDate(r[COL.DATE]);
        const norm  = normaliseStatus(r[COL.STATUS]);
        const score = statusScore(norm);
        if (!d || score === null) return null;
        return {
          x:       d.getTime(),
          y:       score,
          _id:     r._id,
          dateStr: fmtDate(d),
          colony:  r[COL.COLONY] ?? "?",
          location: r[COL.LOCATION] ?? "?",
          statusLabel: statusLabel(norm),
          norm,
        };
      })
      .filter(Boolean)
      .sort((a, b) => a.x - b.x);

    // Colour each point by status level
    const STATUS_COLOURS = { strong: "#2E7D32", neutral: "#F57F17", weak: "#C62828", unknown: "#9E9E9E" };

    if (charts.statusTime) charts.statusTime.destroy();
    charts.statusTime = new Chart($("chart-status-time"), {
      type: "scatter",
      data: {
        datasets: [{
          label: "Hive Status",
          data: statusPoints,
          backgroundColor: statusPoints.map(p => STATUS_COLOURS[p.norm] ?? "#9E9E9E"),
          borderColor:     statusPoints.map(p => STATUS_COLOURS[p.norm] ?? "#9E9E9E"),
          pointRadius: 6,
          pointHoverRadius: 8,
        }],
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: () => "",
              label: ctx => {
                const p = ctx.raw;
                return [
                  p.dateStr,
                  `Colony ${p.colony} @ ${p.location}`,
                  `Status: ${p.statusLabel}`,
                ];
              },
            },
          },
        },
        scales: {
          x: {
            type: "linear",
            grid: { display: false },
            ticks: {
              maxTicksLimit: 8,
              callback: value => {
                const d = new Date(value);
                return d.toLocaleDateString("en-CA", { month: "short", day: "numeric", year: "2-digit" });
              },
            },
          },
          y: {
            min: 0.5,
            max: 3.5,
            ticks: {
              stepSize: 1,
              callback: v => ({ 1: "Weak 👎", 2: "Neutral 👋", 3: "Strong 👍" })[v] ?? "",
            },
            grid: { color: "rgba(0,0,0,0.06)" },
          },
        },
        onClick: (evt, elements) => {
          if (!elements.length) return;
          const p = statusPoints[elements[0].index];
          if (p) scrollToRow(p._id);
        },
        onHover: (evt, elements) => {
          evt.native.target.style.cursor = elements.length ? "pointer" : "default";
        },
      },
    });

    // ── Mite Count Over Time (scatter) ───────────────────────────────
    const mitePoints = rows
      .map(r => {
        const d   = parseDate(r[COL.DATE]);
        const val = parseFloat(r[COL.MITE]);
        if (!d || isNaN(val)) return null;
        return {
          x:        d.getTime(),
          y:        val,
          _id:      r._id,
          dateStr:  fmtDate(d),
          colony:   r[COL.COLONY] ?? "?",
          location: r[COL.LOCATION] ?? "?",
        };
      })
      .filter(Boolean)
      .sort((a, b) => a.x - b.x);

    if (mitePoints.length > 0) {
      miteWrap.style.display = "block";
      if (charts.mites) charts.mites.destroy();
      charts.mites = new Chart($("chart-mites"), {
        type: "scatter",
        data: {
          datasets: [{
            label: "Mite Count",
            data: mitePoints,
            backgroundColor: "rgba(198,40,40,0.75)",
            borderColor: "#C62828",
            pointRadius: 6,
            pointHoverRadius: 8,
          }],
        },
        options: {
          responsive: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                title: () => "",
                label: ctx => {
                  const p = ctx.raw;
                  return [
                    p.dateStr,
                    `Colony ${p.colony} @ ${p.location}`,
                    `Mite count: ${p.y}`,
                  ];
                },
              },
            },
          },
          scales: {
            x: {
              type: "linear",
              grid: { display: false },
              ticks: {
                maxTicksLimit: 8,
                callback: value => {
                  const d = new Date(value);
                  return d.toLocaleDateString("en-CA", { month: "short", day: "numeric", year: "2-digit" });
                },
              },
            },
            y: {
              beginAtZero: true,
              title: { display: true, text: "Mites per 100 bees" },
              grid: { color: "rgba(0,0,0,0.06)" },
            },
          },
          onClick: (evt, elements) => {
            if (!elements.length) return;
            const p = mitePoints[elements[0].index];
            if (p) scrollToRow(p._id);
          },
          onHover: (evt, elements) => {
            evt.native.target.style.cursor = elements.length ? "pointer" : "default";
          },
        },
      });
    } else {
      miteWrap.style.display = "none";
      if (charts.mites) { charts.mites.destroy(); charts.mites = null; }
    }
  }

  // ── Boot ─────────────────────────────────────────────────────────────
  fetchData();
</script>

<style>
  .summary-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin: 1.25rem 0;
  }

  .summary-stat {
    flex: 1;
    min-width: 120px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.2rem;
  }

  .summary-stat span:first-child {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--amber-dark);
    line-height: 1;
  }

  .summary-stat span:last-child {
    font-size: 0.78rem;
    color: var(--charcoal-mid);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Row highlight on chart click */
  @keyframes rowFlash {
    0%   { background-color: var(--amber-light); }
    100% { background-color: transparent; }
  }

  .row-highlight {
    animation: rowFlash 2s ease-out forwards;
  }
</style>
