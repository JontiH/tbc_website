---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import MembersNav from "../../components/MembersNav.astro";
import Footer from "../../components/Footer.astro";

const currentPath = "/members/hive-check";
const WORKER_URL  = import.meta.env.HIVE_WORKER_URL ?? "https://tbc-sheets-worker.jbhmario.workers.dev";
---

<Base
  title="Hive Check Form"
  description="Submit a hive visit record for your TBC colony."
>
  <Nav slot="nav" currentPath={currentPath} />

  <div class="page-header">
    <div class="container page-header-content">
      <h1>Hive Check Form</h1>
      <p>Record your colony visit — health status, mite counts, treatments, and notes.</p>
    </div>
  </div>

  <MembersNav currentPath={currentPath} />

  <!-- SVG filter: expands the hex shape outward by exactly 3px in every
       direction using feMorphology dilate, then floods with amber.
       This is the only reliable way to get a uniform border on a clip-path
       shape — two stacked clip-path polygons always have unequal thickness
       because their diagonal slopes differ when heights differ. -->
  <svg style="display:none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <filter id="hc-hex-border" x="-20%" y="-30%" width="140%" height="160%"
              color-interpolation-filters="sRGB">
        <feMorphology in="SourceAlpha" operator="dilate" radius="3" result="expanded"/>
        <feFlood flood-color="#F5A623" result="amber"/>
        <feComposite in="amber" in2="expanded" operator="in" result="border"/>
        <feMerge>
          <feMergeNode in="border"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
      <filter id="hc-hex-border-active" x="-20%" y="-30%" width="140%" height="160%"
              color-interpolation-filters="sRGB">
        <feMorphology in="SourceAlpha" operator="dilate" radius="3" result="expanded"/>
        <feFlood flood-color="#D4881A" result="amber-dark"/>
        <feComposite in="amber-dark" in2="expanded" operator="in" result="border"/>
        <feMerge>
          <feMergeNode in="border"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>
  </svg>

  <section class="section">
    <div class="container">
      <div class="hc-wrap">

        <div id="hc-loading" class="loading">Loading form…</div>
        <div id="hc-error" style="display:none;" class="error-msg"></div>

        <!-- Form is rendered here by JS -->
        <div id="hc-form-wrap" style="display:none;"></div>

        <!-- Success state -->
        <div id="hc-success" style="display:none;" class="hc-success">
          <div class="hc-success-icon">✓</div>
          <h2>Check recorded!</h2>
          <p>Your hive visit has been saved. It will appear in
            <a href="/members/hive-data">Hive Data</a> within one hour.</p>
          <button id="hc-another" class="btn btn-primary">Submit another check</button>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<script define:vars={{ WORKER_URL }}>
  const $ = id => document.getElementById(id);
  const loadingEl = $("hc-loading");
  const errorEl   = $("hc-error");
  const formWrap  = $("hc-form-wrap");
  const successEl = $("hc-success");

  let formStructure = null;

  // ── Fetch form structure, then identity separately ──────────────────
  async function init() {
    try {
      const formRes = await fetch(`${WORKER_URL}/hive-form`);
      if (!formRes.ok) throw new Error(`HTTP ${formRes.status}`);
      formStructure = await formRes.json();
      loadingEl.style.display = "none";
      renderForm("");          // render immediately — email fills in below
      formWrap.style.display  = "block";
    } catch (err) {
      loadingEl.style.display = "none";
      errorEl.style.display   = "block";
      errorEl.textContent     = `Could not load form: ${err.message}`;
      return;
    }

    // Fetch identity without blocking the form load
    fetchCfEmail().then(email => {
      const form = formWrap.querySelector(".hc-form");
      const bar  = formWrap.querySelector(".hc-identity");
      if (!form) return;
      form.dataset.email = email;
      if (bar) {
        bar.innerHTML = email
          ? `Submitting as <strong>${escHtml(email)}</strong>`
          : `Submitting anonymously — email could not be detected`;
      }
    });
  }

  // ── Section groupings ────────────────────────────────────────────────
  const TITLE_SECTION = {
    "Date of Visit":                                                       "Visit Details",
    "Where is the hive located?":                                          "Visit Details",
    "Which Colony are you checking (A,B,C...)?":                          "Visit Details",
    "How would you describe the holistic status of this hive?":            "Hive Health",
    "What is the mite count? ( leave blank if you didn't check)":          "Hive Health",
    "Are you doing a mite treatment? if so what type of treament?":        "Management",
    "Are you adding feed? if so, what type of feed?":                      "Management",
    "additional comments for this colony":                                 "Notes",
  };

  // Friendly short labels replacing verbose Google Form question text
  const TITLE_LABEL = {
    "Date of Visit":                                                       "Date of Visit",
    "Where is the hive located?":                                          "Hive Location",
    "Which Colony are you checking (A,B,C...)?":                          "Colony",
    "How would you describe the holistic status of this hive?":            "Overall Hive Status",
    "What is the mite count? ( leave blank if you didn't check)":          "Mite Count",
    "Are you doing a mite treatment? if so what type of treament?":        "Mite Treatment",
    "Are you adding feed? if so, what type of feed?":                      "Feed",
    "additional comments for this colony":                                 "Additional Comments",
  };

  // Helper hint text shown below a label
  const TITLE_HINT = {
    "Which Colony are you checking (A,B,C...)?":
      "e.g. A, B, C — as labelled on your hive",
    "What is the mite count? ( leave blank if you didn't check)":
      "Mites per 100 bees. Leave blank if not checked today.",
  };

  // ── Read email from Cloudflare Access identity endpoint ─────────────
  // CF_Authorization is HttpOnly in current CF Access versions — can't read
  // it from JS. /cdn-cgi/access/get-identity is served by Cloudflare on any
  // Access-protected domain and returns the authenticated user's details.
  async function fetchCfEmail() {
    try {
      const res = await fetch("/cdn-cgi/access/get-identity");
      if (!res.ok) return "";
      const data = await res.json();
      return data.email ?? "";
    } catch {
      return "";
    }
  }

  // ── Render form from structure ───────────────────────────────────────
  function renderForm(email = "") {
    const { description, items } = formStructure;

    const visibleItems = items.filter(i => i.type !== "file_upload" && i.type !== "unknown");

    const form = document.createElement("form");
    form.className  = "hc-form";
    form.noValidate = true;

    // Identity banner — always shown at the top
    const identityBar = document.createElement("div");
    identityBar.className = "hc-identity";
    identityBar.innerHTML = email
      ? `Submitting as <strong>${escHtml(email)}</strong>`
      : `Submitting anonymously — email could not be detected`;
    form.appendChild(identityBar);

    // Optional Google Form description
    if (description) {
      const banner = document.createElement("div");
      banner.className = "hc-description";
      banner.innerHTML = `<p>${escHtml(description)}</p>`;
      form.appendChild(banner);
    }

    // Render questions grouped into numbered section cards
    let currentSection  = null;
    let sectionBody     = null;
    let sectionCount    = 0;

    for (const item of visibleItems) {
      const section = TITLE_SECTION[item.title] ?? "Other";

      if (section !== currentSection) {
        currentSection = section;
        sectionCount++;

        const sectionEl = document.createElement("div");
        sectionEl.className = "hc-section";

        const sectionHdr = document.createElement("div");
        sectionHdr.className = "hc-section-header";
        sectionHdr.innerHTML =
          `<span class="hc-section-num">${sectionCount}</span>` +
          `<span class="hc-section-title">${escHtml(section)}</span>`;
        sectionEl.appendChild(sectionHdr);

        sectionBody = document.createElement("div");
        sectionBody.className = "hc-section-body";
        sectionEl.appendChild(sectionBody);

        form.appendChild(sectionEl);
      }

      sectionBody.appendChild(buildQuestion(item));
    }

    // Submit block
    const submitBlock = document.createElement("div");
    submitBlock.className = "hc-submit-block";

    const submit = document.createElement("button");
    submit.type        = "submit";
    submit.className   = "btn btn-primary hc-submit";
    submit.textContent = "Submit hive check";
    submitBlock.appendChild(submit);

    form.appendChild(submitBlock);

    form.dataset.email = email;
    form.addEventListener("submit", handleSubmit);
    formWrap.innerHTML = "";
    formWrap.appendChild(form);
  }

  function escHtml(s) {
    return (s ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  // ── Build individual question elements ───────────────────────────────
  function buildQuestion(item) {
    const wrap = document.createElement("div");
    wrap.className       = "hc-question";
    wrap.dataset.entryId = item.entryId;
    wrap.dataset.type    = item.type;

    const labelText = TITLE_LABEL[item.title] ?? item.title;
    const label = document.createElement("div");
    label.className = "hc-label";
    label.innerHTML = escHtml(labelText)
      + (item.required ? ' <span class="hc-req" aria-label="required">*</span>' : "");
    wrap.appendChild(label);

    const hint = TITLE_HINT[item.title];
    if (hint) {
      const hintEl = document.createElement("p");
      hintEl.className   = "hc-hint";
      hintEl.textContent = hint;
      wrap.appendChild(hintEl);
    }

    if (item.type === "date") {
      const input = document.createElement("input");
      input.type      = "date";
      input.className = "hc-input hc-input-short";
      input.required  = item.required;
      input.value     = new Date().toISOString().slice(0, 10);
      wrap.appendChild(input);

    } else if (item.type === "text") {
      const input = document.createElement("input");
      input.type      = "text";
      input.className = "hc-input hc-input-short";
      input.required  = item.required;
      wrap.appendChild(input);

    } else if (item.type === "textarea") {
      const ta = document.createElement("textarea");
      ta.className = "hc-textarea";
      ta.required  = item.required;
      ta.rows      = 5;
      wrap.appendChild(ta);

    } else if (item.type === "radio" || item.type === "checkbox") {
      const group = document.createElement("div");
      group.className = "hc-pill-group";

      let otherInput = null;

      for (const opt of item.options) {
        // Shell carries the SVG filter; pill carries the clip-path.
        // Filter is set via inline style so the url('#id') fragment resolves
        // against the document — external stylesheets can resolve '#id' against
        // the CSS file URL instead, causing the filter to silently fail.
        const shell = document.createElement("span");
        shell.className = "hc-pill-shell";
        shell.style.filter = "url('#hc-hex-border')";

        const pill = document.createElement("label");
        pill.className = "hc-pill";

        const input = document.createElement("input");
        input.type      = item.type === "checkbox" ? "checkbox" : "radio";
        input.name      = `entry_${item.entryId}`;
        input.value     = opt.isOther ? "__other_option__" : opt.value;
        input.className = "hc-pill-input";
        input.id        = `entry_${item.entryId}_${opt.isOther ? "other" : opt.value.replace(/\s+/g,"_")}`;
        if (!opt.isOther) input.required = item.required;

        pill.appendChild(input);
        pill.appendChild(document.createTextNode(opt.isOther ? "Other" : opt.value));
        shell.appendChild(pill);
        group.appendChild(shell);

        // Swap filter inline on check/uncheck so fragment URL resolves correctly
        input.addEventListener("change", () => {
          group.querySelectorAll(".hc-pill-shell").forEach(s => {
            s.style.filter = "url('#hc-hex-border')";
          });
          if (input.checked) shell.style.filter = "url('#hc-hex-border-active')";
        });

        if (opt.isOther) {
          otherInput = document.createElement("input");
          otherInput.type             = "text";
          otherInput.className        = "hc-other-input";
          otherInput.placeholder      = "Please specify";
          otherInput.disabled         = true;
          otherInput.dataset.forEntry = item.entryId;

          input.addEventListener("change", () => {
            otherInput.disabled = !input.checked;
            if (input.checked) otherInput.focus();
          });
        }
      }

      wrap.appendChild(group);
      if (otherInput) wrap.appendChild(otherInput);
    }

    return wrap;
  }

  // Maps form question titles → JSON keys the Worker expects
  const TITLE_KEY = {
    "Date of Visit":                                                      "date",
    "Where is the hive located?":                                         "location",
    "Which Colony are you checking (A,B,C...)?":                          "colony",
    "How would you describe the holistic status of this hive?":           "status",
    "Are you doing a mite treatment? if so what type of treament?":       "treatment",
    "Are you adding feed? if so, what type of feed?":                     "feed",
    "What is the mite count? ( leave blank if you didn't check)":         "mite_count",
    "additional comments for this colony":                                "comments",
  };

  // ── Form submission ──────────────────────────────────────────────────
  async function handleSubmit(e) {
    e.preventDefault();
    const form      = e.target;
    const submitBtn = form.querySelector(".hc-submit");

    let valid = true;
    form.querySelectorAll(".hc-question").forEach(q => q.classList.remove("hc-invalid"));

    const payload = {};

    for (const item of formStructure.items) {
      if (item.type === "file_upload" || item.type === "unknown") continue;

      const key = TITLE_KEY[item.title];
      if (!key) continue;

      const qEl = form.querySelector(`[data-entry-id="${item.entryId}"]`);
      if (!qEl) continue;

      let value = "";

      if (item.type === "date") {
        const raw = qEl.querySelector("input").value; // YYYY-MM-DD
        if (!raw && item.required) { qEl.classList.add("hc-invalid"); valid = false; continue; }
        if (raw) {
          const [y, m, d] = raw.split("-");
          value = `${d}/${m}/${y}`; // DD/MM/YYYY — matches existing sheet format
        }

      } else if (item.type === "text") {
        value = qEl.querySelector("input").value.trim();
        if (!value && item.required) { qEl.classList.add("hc-invalid"); valid = false; continue; }

      } else if (item.type === "textarea") {
        value = qEl.querySelector("textarea").value.trim();
        if (!value && item.required) { qEl.classList.add("hc-invalid"); valid = false; continue; }

      } else if (item.type === "radio") {
        const checked = qEl.querySelector(`input[name="entry_${item.entryId}"]:checked`);
        if (!checked && item.required) { qEl.classList.add("hc-invalid"); valid = false; continue; }
        if (checked) {
          value = checked.value === "__other_option__"
            ? (qEl.querySelector(`.hc-other-input[data-for-entry="${item.entryId}"]`)?.value.trim() ?? "")
            : checked.value;
        }
      }

      payload[key] = value;
    }

    if (!valid) {
      form.querySelector(".hc-invalid")?.scrollIntoView({ behavior: "smooth", block: "center" });
      return;
    }

    payload.email = form.dataset.email ?? "";

    submitBtn.disabled    = true;
    submitBtn.textContent = "Submitting…";

    try {
      const res = await fetch(`${WORKER_URL}/hive-form-submit`, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify(payload),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: `HTTP ${res.status}` }));
        throw new Error(err.error ?? `HTTP ${res.status}`);
      }

      formWrap.style.display  = "none";
      successEl.style.display = "block";
      successEl.scrollIntoView({ behavior: "smooth", block: "center" });

    } catch (err) {
      submitBtn.disabled    = false;
      submitBtn.textContent = "Submit hive check";
      alert(`Submission failed: ${err.message}`);
    }
  }

  $("hc-another").addEventListener("click", async () => {
    successEl.style.display = "none";
    const email = await fetchCfEmail();
    renderForm(email);
    formWrap.style.display  = "block";
    formWrap.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  init();
</script>

<style is:global>
  /* ── Page wrapper ────────────────────────────────────────────────── */
  .hc-wrap {
    max-width: 680px;
    margin: 0 auto;
  }

  /* ── Form: flex column of section cards ─────────────────────────── */
  .hc-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Identity banner ────────────────────────────────────────────── */
  .hc-identity {
    padding: 0.75rem 1.25rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-left: 4px solid var(--amber);
    border-radius: var(--radius);
    font-size: 0.88rem;
    color: var(--charcoal-mid);
    line-height: 1.4;
  }

  .hc-identity strong {
    color: var(--charcoal);
    font-weight: 600;
  }

  .hc-identity-unknown {
    color: var(--status-bad);
  }

  /* Optional description banner from Google Form */
  .hc-description {
    padding: 1rem 1.5rem;
    background: var(--amber-light);
    border: 1px solid var(--border);
    border-left: 4px solid var(--amber);
    border-radius: var(--radius);
    font-size: 0.9rem;
    color: var(--charcoal-mid);
    line-height: 1.55;
  }
  .hc-description p { margin: 0; }

  /* ── Section cards ───────────────────────────────────────────────── */
  .hc-section {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .hc-section-header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1rem 1.75rem;
    background: var(--cream);
    border-bottom: 2px solid var(--border);
  }

  /* Numbered amber circle badge */
  .hc-section-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: var(--amber);
    color: var(--white);
    font-size: 0.78rem;
    font-weight: 800;
    border-radius: 50%;
    flex-shrink: 0;
    line-height: 1;
  }

  .hc-section-title {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--charcoal);
  }

  .hc-section-body {
    background: var(--white);
  }

  /* ── Questions ───────────────────────────────────────────────────── */
  .hc-question {
    padding: 1.5rem 1.75rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
  }

  .hc-question:last-child {
    border-bottom: none;
  }

  .hc-question.hc-invalid {
    background: #fff5f5;
  }

  .hc-question.hc-invalid .hc-label {
    color: var(--status-bad);
  }

  .hc-question.hc-invalid .hc-input,
  .hc-question.hc-invalid .hc-textarea {
    border-color: var(--status-bad);
    box-shadow: 0 0 0 3px rgba(198,40,40,0.08);
  }

  /* ── Labels ──────────────────────────────────────────────────────── */
  .hc-label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 0.45rem;
    line-height: 1.4;
  }

  .hc-req {
    color: var(--amber-dark);
    margin-left: 3px;
  }

  .hc-hint {
    font-size: 0.82rem;
    color: var(--charcoal-mid);
    margin: 0 0 0.65rem;
    line-height: 1.45;
  }

  /* ── Text inputs ─────────────────────────────────────────────────── */
  .hc-input,
  .hc-textarea {
    width: 100%;
    padding: 0.6rem 0.85rem;
    border: 1.5px solid var(--border);
    border-radius: 7px;
    font-family: inherit;
    font-size: 0.93rem;
    color: var(--charcoal);
    background: #fff;
    box-sizing: border-box;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .hc-input-short { max-width: 260px; }

  .hc-input:focus,
  .hc-textarea:focus {
    outline: none;
    border-color: var(--amber);
    box-shadow: 0 0 0 3px rgba(245,166,35,0.18);
  }

  .hc-textarea {
    resize: vertical;
    min-height: 110px;
    line-height: 1.55;
  }

  /* ── Honeycomb radio / checkbox options ─────────────────────────── */
  /*
   * Single element approach using an SVG feMorphology filter for the border.
   * feMorphology "dilate" expands the alpha mask outward by exactly 3px in
   * every direction — perfectly uniform regardless of angle. No two-layer
   * clip-path geometry needed.
   */
  .hc-pill-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.5rem;
    margin-top: 0.25rem;
  }

  /* Shell: holds the SVG border filter (set via inline style in JS) */
  .hc-pill-shell {
    display: inline-flex;
    cursor: pointer;
  }

  /* Pill: holds the hex clip-path and fill — no filter here */
  .hc-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 36px;
    padding: 0 calc(0.9rem + 11px);
    background: var(--cream);
    clip-path: polygon(
      11px 0%,
      calc(100% - 11px) 0%,
      100% 50%,
      calc(100% - 11px) 100%,
      11px 100%,
      0% 50%
    );
    font-size: 0.88rem;
    color: var(--charcoal);
    user-select: none;
    white-space: nowrap;
    line-height: 1;
    transition: background 0.12s, color 0.12s;
  }

  .hc-pill-shell:hover .hc-pill {
    background: var(--amber-light);
  }

  .hc-pill-shell:has(.hc-pill-input:checked) .hc-pill {
    background: var(--amber);
    color: var(--white);
    font-weight: 600;
  }

  .hc-pill-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  /* "Other" free-text input */
  .hc-other-input {
    display: block;
    width: 100%;
    max-width: 380px;
    margin-top: 0.65rem;
    padding: 0.55rem 0.85rem;
    border: 1.5px solid var(--border);
    border-radius: 7px;
    font-family: inherit;
    font-size: 0.9rem;
    color: var(--charcoal);
    background: #fff;
    box-sizing: border-box;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .hc-other-input:disabled {
    background: #f5f5f5;
    color: #bbb;
    border-style: dashed;
  }

  .hc-other-input:focus {
    outline: none;
    border-color: var(--amber);
    box-shadow: 0 0 0 3px rgba(245,166,35,0.18);
  }

  /* ── Submit block ────────────────────────────────────────────────── */
  .hc-submit-block {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    padding: 0.5rem 0 1rem;
  }

  .hc-submit {
    padding: 0.75rem 2rem;
    font-size: 0.97rem;
    letter-spacing: 0.01em;
  }

  .hc-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* ── Success card ────────────────────────────────────────────────── */
  .hc-success {
    text-align: center;
    padding: 3.5rem 2rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 4px solid var(--status-good);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }

  .hc-success-icon {
    width: 64px;
    height: 64px;
    background: var(--status-good-bg);
    color: var(--status-good);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 auto 1.25rem;
  }

