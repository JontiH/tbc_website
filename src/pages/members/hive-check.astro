---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import MembersNav from "../../components/MembersNav.astro";
import Footer from "../../components/Footer.astro";

const currentPath = "/members/hive-check";
const WORKER_URL  = import.meta.env.HIVE_WORKER_URL ?? "https://tbc-sheets-worker.jbhmario.workers.dev";
---

<Base
  title="Hive Check Form"
  description="Submit a hive visit record for your TBC colony."
>
  <Nav slot="nav" currentPath={currentPath} />

  <div class="page-header">
    <div class="container page-header-content">
      <h1>Hive Check Form</h1>
      <p>Record your colony visit — health status, mite counts, treatments, and notes.</p>
    </div>
  </div>

  <MembersNav currentPath={currentPath} />

  <section class="section">
    <div class="container">
      <div class="hc-wrap">

        <div id="hc-loading" class="loading">Loading form…</div>
        <div id="hc-error"   style="display:none;" class="error-msg"></div>

        <!-- Form is rendered here by JS -->
        <div id="hc-form-wrap" style="display:none;"></div>

        <!-- Success state -->
        <div id="hc-success" style="display:none;" class="hc-success">
          <div class="hc-success-icon">✓</div>
          <h2>Submitted!</h2>
          <p>Your hive check has been recorded. It will appear in
            <a href="/members/hive-data">Hive Data</a> within one hour.</p>
          <button id="hc-another" class="btn btn-primary">Submit another check</button>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<script define:vars={{ WORKER_URL }}>
  const $ = id => document.getElementById(id);
  const loadingEl  = $("hc-loading");
  const errorEl    = $("hc-error");
  const formWrap   = $("hc-form-wrap");
  const successEl  = $("hc-success");

  let formStructure = null;

  // ── Fetch form structure from Worker ────────────────────────────────
  async function init() {
    try {
      const res = await fetch(`${WORKER_URL}/hive-form`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      formStructure = await res.json();
      loadingEl.style.display = "none";
      renderForm();
      formWrap.style.display  = "block";
    } catch (err) {
      loadingEl.style.display = "none";
      errorEl.style.display   = "block";
      errorEl.textContent     = `Could not load form: ${err.message}`;
    }
  }

  // ── Render form from structure ───────────────────────────────────────
  function renderForm() {
    const { title, description, items, submitUrl, responderUri } = formStructure;

    const form = document.createElement("form");
    form.className  = "hc-form";
    form.noValidate = true;

    // Header
    const hdr = document.createElement("div");
    hdr.className = "hc-form-header";
    hdr.innerHTML = `<h2 class="hc-form-title">${escHtml(title)}</h2>`
                  + (description ? `<p class="hc-form-desc">${escHtml(description)}</p>` : "");
    form.appendChild(hdr);

    // Questions
    for (const item of items) {
      if (item.type === "file_upload") {
        form.appendChild(buildFileUploadNote(item, responderUri));
        continue;
      }
      form.appendChild(buildQuestion(item));
    }

    // Submit row
    const footer = document.createElement("div");
    footer.className = "hc-form-footer";

    const submit = document.createElement("button");
    submit.type      = "submit";
    submit.className = "btn btn-primary hc-submit";
    submit.textContent = "Submit hive check";
    footer.appendChild(submit);

    const note = document.createElement("p");
    note.className   = "hc-submit-note";
    note.innerHTML   = `Responses go directly to the TBC hive data sheet.`;
    footer.appendChild(note);

    form.appendChild(footer);

    form.addEventListener("submit", e => handleSubmit(e, submitUrl));
    formWrap.innerHTML = "";
    formWrap.appendChild(form);
  }

  function escHtml(s) {
    return (s ?? "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  // ── Build individual question elements ───────────────────────────────
  function buildQuestion(item) {
    const wrap = document.createElement("div");
    wrap.className = "hc-question";
    wrap.dataset.entryId = item.entryId;
    wrap.dataset.type    = item.type;

    const label = document.createElement("div");
    label.className = "hc-label";
    label.innerHTML = escHtml(item.title) + (item.required ? ' <span class="hc-req" aria-label="required">*</span>' : "");
    wrap.appendChild(label);

    if (item.type === "date") {
      const input = document.createElement("input");
      input.type      = "date";
      input.className = "hc-input";
      input.required  = item.required;
      // Default to today
      input.value = new Date().toISOString().slice(0, 10);
      wrap.appendChild(input);

    } else if (item.type === "text") {
      const input = document.createElement("input");
      input.type      = "text";
      input.className = "hc-input";
      input.required  = item.required;
      wrap.appendChild(input);

    } else if (item.type === "textarea") {
      const ta = document.createElement("textarea");
      ta.className = "hc-textarea";
      ta.required  = item.required;
      ta.rows      = 4;
      wrap.appendChild(ta);

    } else if (item.type === "radio" || item.type === "checkbox") {
      const group = document.createElement("div");
      group.className = "hc-radio-group";

      for (const opt of item.options) {
        if (opt.isOther) {
          // "Other" option with a text input
          const otherWrap = document.createElement("div");
          otherWrap.className = "hc-radio-row hc-other-row";

          const radio = document.createElement("input");
          radio.type  = item.type === "checkbox" ? "checkbox" : "radio";
          radio.name  = `entry_${item.entryId}`;
          radio.value = "__other_option__";
          radio.className = "hc-radio";
          radio.id    = `entry_${item.entryId}_other`;

          const otherLabel = document.createElement("label");
          otherLabel.htmlFor   = radio.id;
          otherLabel.className = "hc-radio-label";
          otherLabel.textContent = "Other:";

          const otherInput = document.createElement("input");
          otherInput.type      = "text";
          otherInput.className = "hc-other-input";
          otherInput.placeholder = "Please specify";
          otherInput.disabled  = true;
          otherInput.dataset.forEntry = item.entryId;

          radio.addEventListener("change", () => {
            otherInput.disabled = !radio.checked;
            if (radio.checked) otherInput.focus();
          });

          otherWrap.appendChild(radio);
          otherWrap.appendChild(otherLabel);
          otherWrap.appendChild(otherInput);
          group.appendChild(otherWrap);
        } else {
          const row = document.createElement("div");
          row.className = "hc-radio-row";

          const radio = document.createElement("input");
          radio.type  = item.type === "checkbox" ? "checkbox" : "radio";
          radio.name  = `entry_${item.entryId}`;
          radio.value = opt.value;
          radio.className = "hc-radio";
          radio.id    = `entry_${item.entryId}_${opt.value.replace(/\s+/g,"_")}`;
          radio.required = item.required;

          const rl = document.createElement("label");
          rl.htmlFor   = radio.id;
          rl.className = "hc-radio-label";
          rl.textContent = opt.value;

          row.appendChild(radio);
          row.appendChild(rl);
          group.appendChild(row);
        }
      }
      wrap.appendChild(group);
    }

    return wrap;
  }

  function buildFileUploadNote(item, responderUri) {
    const wrap = document.createElement("div");
    wrap.className = "hc-question hc-file-note";
    wrap.innerHTML = `
      <div class="hc-label">${escHtml(item.title)}</div>
      <p class="hc-file-note-text">
        File uploads aren't supported in this form. To add photos or videos, open the
        <a href="${escHtml(responderUri)}" target="_blank" rel="noopener">original Google Form ↗</a>
        and attach them there after submitting here.
      </p>`;
    return wrap;
  }

  // ── Form submission ──────────────────────────────────────────────────
  async function handleSubmit(e, submitUrl) {
    e.preventDefault();
    const form = e.target;
    const submitBtn = form.querySelector(".hc-submit");

    // Client-side validation
    let valid = true;
    form.querySelectorAll(".hc-question").forEach(q => {
      q.classList.remove("hc-invalid");
    });

    const params = new URLSearchParams();

    for (const item of formStructure.items) {
      if (item.type === "file_upload") continue;

      const qEl = form.querySelector(`[data-entry-id="${item.entryId}"]`);
      if (!qEl) continue;

      if (item.type === "date") {
        const val = qEl.querySelector("input").value;
        if (!val && item.required) { qEl.classList.add("hc-invalid"); valid = false; continue; }
        if (val) {
          const [y, m, d] = val.split("-").map(Number);
          params.append(`entry.${item.entryId}_year`,  y);
          params.append(`entry.${item.entryId}_month`, m);
          params.append(`entry.${item.entryId}_day`,   d);
        }

      } else if (item.type === "text") {
        const val = qEl.querySelector("input").value.trim();
        if (!val && item.required) { qEl.classList.add("hc-invalid"); valid = false; continue; }
        if (val) params.append(`entry.${item.entryId}`, val);

      } else if (item.type === "textarea") {
        const val = qEl.querySelector("textarea").value.trim();
        if (!val && item.required) { qEl.classList.add("hc-invalid"); valid = false; continue; }
        if (val) params.append(`entry.${item.entryId}`, val);

      } else if (item.type === "radio") {
        const checked = qEl.querySelector(`input[name="entry_${item.entryId}"]:checked`);
        if (!checked && item.required) { qEl.classList.add("hc-invalid"); valid = false; continue; }
        if (checked) {
          params.append(`entry.${item.entryId}`, checked.value);
          if (checked.value === "__other_option__") {
            const otherText = qEl.querySelector(`.hc-other-input[data-for-entry="${item.entryId}"]`)?.value.trim() ?? "";
            params.append(`entry.${item.entryId}.other_option_response`, otherText);
          }
        }
      }
    }

    if (!valid) {
      form.querySelector(".hc-invalid")?.scrollIntoView({ behavior: "smooth", block: "center" });
      return;
    }

    submitBtn.disabled     = true;
    submitBtn.textContent  = "Submitting…";

    try {
      // mode: no-cors because Google's formResponse endpoint doesn't send CORS headers.
      // The fetch always "succeeds" (opaque response) as long as it doesn't throw.
      await fetch(submitUrl, {
        method:  "POST",
        mode:    "no-cors",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body:    params.toString(),
      });

      formWrap.style.display  = "none";
      successEl.style.display = "block";

    } catch (err) {
      submitBtn.disabled    = false;
      submitBtn.textContent = "Submit hive check";
      alert(`Submission failed: ${err.message}. Please try the original form link.`);
    }
  }

  // ── "Submit another" button ──────────────────────────────────────────
  $("hc-another").addEventListener("click", () => {
    successEl.style.display = "none";
    renderForm();
    formWrap.style.display  = "block";
  });

  init();
</script>

<style>
  .hc-wrap {
    max-width: 680px;
    margin: 0 auto;
  }

  /* ── Form card ───────────────────────────────────────────────────── */
  .hc-form {
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 4px solid var(--amber);
    border-radius: var(--radius);
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    overflow: hidden;
  }

  .hc-form-header {
    padding: 1.5rem 1.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--cream);
  }

  .hc-form-title {
    font-size: 1.2rem;
    margin-bottom: 0.35rem;
  }

  .hc-form-desc {
    font-size: 0.88rem;
    color: var(--charcoal-mid);
    margin: 0;
  }

  /* ── Questions ───────────────────────────────────────────────────── */
  .hc-question {
    padding: 1.25rem 1.75rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }

  .hc-question:last-of-type { border-bottom: none; }

  .hc-question.hc-invalid { background: #fff5f5; }
  .hc-question.hc-invalid .hc-label { color: #c62828; }

  .hc-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 0.65rem;
    line-height: 1.4;
  }

  .hc-req { color: var(--amber-dark); margin-left: 2px; }

  /* ── Inputs ──────────────────────────────────────────────────────── */
  .hc-input,
  .hc-textarea {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.9rem;
    color: var(--charcoal);
    background: #fff;
    box-sizing: border-box;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .hc-input:focus,
  .hc-textarea:focus {
    outline: none;
    border-color: var(--amber);
    box-shadow: 0 0 0 3px rgba(245,166,35,0.15);
  }

  .hc-textarea { resize: vertical; min-height: 90px; }

  /* ── Radio / checkbox groups ─────────────────────────────────────── */
  .hc-radio-group { display: flex; flex-direction: column; gap: 0.45rem; }

  .hc-radio-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .hc-radio {
    width: 16px;
    height: 16px;
    accent-color: var(--amber);
    flex-shrink: 0;
    cursor: pointer;
  }

  .hc-radio-label {
    font-size: 0.88rem;
    color: var(--charcoal);
    cursor: pointer;
    line-height: 1.3;
  }

  .hc-other-row { flex-wrap: wrap; gap: 0.4rem; }

  .hc-other-input {
    flex: 1;
    min-width: 160px;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.85rem;
    color: var(--charcoal);
    background: #fff;
  }
  .hc-other-input:disabled { background: #f5f5f5; color: #aaa; }
  .hc-other-input:focus { outline: none; border-color: var(--amber); }

  /* ── File upload note ────────────────────────────────────────────── */
  .hc-file-note { background: var(--amber-light); }
  .hc-file-note-text {
    font-size: 0.85rem;
    color: var(--charcoal-mid);
    margin: 0;
  }
  .hc-file-note-text a { color: var(--amber-dark); font-weight: 600; }

  /* ── Footer ──────────────────────────────────────────────────────── */
  .hc-form-footer {
    padding: 1.25rem 1.75rem;
    background: var(--cream);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hc-submit { padding: 0.65rem 1.75rem; font-size: 0.95rem; }
  .hc-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .hc-submit-note {
    font-size: 0.8rem;
    color: var(--charcoal-mid);
    margin: 0;
  }

  /* ── Success ─────────────────────────────────────────────────────── */
  .hc-success {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-top: 4px solid #2E7D32;
    border-radius: var(--radius);
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  }

  .hc-success-icon {
    font-size: 2.5rem;
    color: #2E7D32;
    margin-bottom: 0.75rem;
  }

  .hc-success h2 { margin-bottom: 0.5rem; }

  .hc-success p {
    color: var(--charcoal-mid);
    font-size: 0.92rem;
    margin-bottom: 1.5rem;
  }

  .hc-success a { color: var(--amber-dark); font-weight: 600; text-decoration: none; }
  .hc-success a:hover { text-decoration: underline; }

  @media (max-width: 600px) {
    .hc-question     { padding: 1rem 1.1rem; }
    .hc-form-header  { padding: 1.1rem 1.1rem 1rem; }
    .hc-form-footer  { padding: 1rem 1.1rem; }
  }
</style>
